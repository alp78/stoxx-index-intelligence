@* App shell: top nav bar, MudBlazor theme, and error boundary around routed content. *@
@inherits LayoutComponentBase
@inject NavigationManager Nav
@implements IDisposable

@* MudBlazor infrastructure providers — must appear once at layout level *@
<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Fixed="true" Dense="true">
        <MudText Typo="Typo.subtitle1" Class="ml-2" Style="font-weight: 600; letter-spacing: 1px; font-size: 0.85rem;">
            STOXX Index Intelligence
        </MudText>
        <MudSpacer />
        @* Nav buttons — highlight active page via prefix match on the current path *@
        @foreach (var nav in _navItems)
        {
            var n = nav;
            var active = IsActive(n.Href);
            <MudButton Color="Color.Inherit"
                       StartIcon="@n.Icon"
                       OnClick="@(() => Nav.NavigateTo(n.Href))"
                       Style="@($"text-transform: none; margin: 0 8px; padding: 8px 36px; font-size: 0.95rem; {(active ? "background: rgba(255,255,255,0.12); font-weight: 700;" : "opacity: 0.7;")}")">
                @n.Label
            </MudButton>
        }
        <MudSpacer />
    </MudAppBar>

    <MudMainContent Class="pa-4 mt-12">
        @* ErrorBoundary catches unhandled exceptions in child pages and shows a recovery link
           instead of crashing the entire Blazor circuit. *@
        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>@Body</ChildContent>
            <ErrorContent>
                <MudAlert Severity="MudBlazor.Severity.Error" Class="ma-4">
                    Something went wrong. <MudLink OnClick="Recover">Try again</MudLink>
                </MudAlert>
            </ErrorContent>
        </ErrorBoundary>
    </MudMainContent>
</MudLayout>

@code {
    private record NavItem(string Href, string Label, string Icon);

    private static readonly NavItem[] _navItems =
    [
        new("/", "OVERVIEW", Icons.Material.Filled.Insights),
        new("/stocks", "STOCKS", Icons.Material.Filled.ListAlt),
        new("/sectors", "SECTORS", Icons.Material.Filled.PieChart),
        new("/live", "PULSE", Icons.Material.Filled.MonitorHeart),
    ];

    private ErrorBoundary? _errorBoundary;
    private string _currentPath = "/";

    // Subscribe to navigation events so the active nav button updates on SPA transitions.
    protected override void OnInitialized()
    {
        _currentPath = GetPath();
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _currentPath = GetPath();
        InvokeAsync(StateHasChanged);
    }

    private string GetPath() => new Uri(Nav.Uri).AbsolutePath.TrimEnd('/');

    // Root "/" is exact-match only; other routes use prefix match (e.g., "/stocks/..." highlights STOCKS).
    private bool IsActive(string href)
    {
        if (href == "/") return _currentPath is "" or "/";
        return _currentPath.StartsWith(href, StringComparison.OrdinalIgnoreCase);
    }

    private void Recover() => _errorBoundary?.Recover();

    // Unsubscribe to prevent memory leaks — layout outlives individual pages.
    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;

    // Dark-first theme — PaletteLight is set for completeness but IsDarkMode is always true.
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1565C0",
            Secondary = "#00897B",
            AppbarBackground = "#0D47A1",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#42A5F5",
            Secondary = "#26A69A",
            Surface = "#1E1E2D",
            Background = "#151521",
            AppbarBackground = "#1A1A2E",
            DrawerBackground = "#1A1A2E",
            TextPrimary = "#E0E0E0",
            TextSecondary = "#A0A0B0",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography { FontFamily = ["Inter", "Helvetica", "Arial", "sans-serif"] },
        },
    };
}
