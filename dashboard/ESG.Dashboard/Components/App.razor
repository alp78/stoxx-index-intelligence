@using static Microsoft.AspNetCore.Components.Web.RenderMode
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.0.0/css/flag-icons.min.css" integrity="sha384-aQuvIWWIbpu/mSqULLDiUveyYiPoJzPKAWjUmGJ+Elm+N/LJhzfZqsutsfw870JS" crossorigin="anonymous" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["ESG.Dashboard.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="_content/LightweightCharts.Blazor/lightweight-charts.standalone.js"></script>
    <script src="_content/LightweightCharts.Blazor/lightweight-charts.scripts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js" integrity="sha384-vsrfeLOOY6KuIYKDlmVH5UiBmgIdB1oEf7p01YgWHuqmOHfZr374+odEv96n9tNC" crossorigin="anonymous"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        // Auto-reload when Blazor Server circuit is lost and cannot reconnect
        (() => {
            let retries = 0;
            const maxRetries = 8;
            const observer = new MutationObserver(() => {
                const modal = document.getElementById('components-reconnect-modal');
                if (!modal) return;
                if (modal.classList.contains('components-reconnect-rejected') ||
                    modal.classList.contains('components-reconnect-failed')) {
                    location.reload();
                }
                if (modal.classList.contains('components-reconnect-show')) {
                    retries++;
                    if (retries > maxRetries) location.reload();
                }
                if (modal.classList.contains('components-reconnect-hide')) {
                    retries = 0;
                }
            });
            observer.observe(document.body, { childList: true, subtree: true, attributes: true, attributeFilter: ['class'] });
        })();
    </script>
    <div id="components-reconnect-modal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.7);justify-content:center;align-items:center;font-family:Inter,sans-serif;color:#e0e0e0;">
        <div style="text-align:center;">
            <div style="font-size:1.2rem;margin-bottom:8px;">Reconnecting...</div>
            <div style="opacity:0.5;font-size:0.85rem;">If this persists, refresh the page.</div>
        </div>
    </div>
    <style>
        #components-reconnect-modal.components-reconnect-show { display: flex !important; }
        #components-reconnect-modal.components-reconnect-hide { display: none !important; }
        #components-reconnect-modal.components-reconnect-failed { display: flex !important; }
        #components-reconnect-modal.components-reconnect-rejected { display: flex !important; }
    </style>
</body>

</html>
