        .Where(d => d.Index == _selectedSignalIndex)
        .OrderBy(d => d.SentimentRank).Take(10);

    private IEnumerable<ScoreDaily> DivergenceAlerts => _daily
        .Where(d => d.Index == _selectedSignalIndex && d.PriceFallingAnalystsBullish == true)
        .OrderByDescending(d => d.ImpliedUpside);

