    // ── Period & tooltip helpers ──

    private DateTime? GetPeriodCutoff()
    {
        var p = _periods.FirstOrDefault(p => p.Key == _selectedPeriod);
        return p.GetStart?.Invoke(DateTime.UtcNow);
    }

    private async Task SendTooltipData(ElementReference container,
        Dictionary<long, (DateTime Date, Dictionary<string, double> Values)> lookup, bool colorBySign)
    {
        if (_jsModule is null) return;
        var jsLookup = lookup.ToDictionary(
            k => k.Key.ToString(),
            k => new { date = k.Value.Date.ToString("dd MMM yyyy"), values = k.Value.Values });
        var indices = new[] { new { key = _selectedSignalIndex, name = FormatIndexName(_selectedSignalIndex), color = IndexColor(_selectedSignalIndex) } };
        await _jsModule.InvokeVoidAsync("setTooltipData", container, jsLookup, indices, new { colorBySign });
    }

    // Switches the active index: fires DB load for momentum closes in parallel, then updates
    // each chart sequentially (parallel JS interop deadlocks the SignalR circuit).
    private async Task OnSignalIndexChanged(string newIndex)
    {
        if (_disposed) return;
        _selectedSignalIndex = newIndex;
        IdxState.SelectedIndex = newIndex;

        try
        {
            var momTask = LoadMomentumCloses();

            // Single JS call updates all 3 line charts at once (synthetic + rolling + vol).
            await BatchUpdateAllLineCharts();
            if (_radarReady) await UpdateRadarChart();
            if (_donutReady) await UpdateDonutChart();

            await momTask;
            if (_momReady)
                await UpdateMomData();
        }
        catch (ObjectDisposedException) { }
        catch (Microsoft.JSInterop.JSDisconnectedException) { }
    }

    // Period switch re-filters the pre-loaded 3Y data — no DB call.
    // Brief opacity transition (_momTransitioning) avoids a jarring visual snap.
    private async Task SetMomPeriod(string period)
    {
        if (_disposed) return;
        _selectedMomPeriod = period;
        try
        {
            if (_momReady)
            {
                _momTransitioning = true;
                StateHasChanged();
                await Task.Delay(20);
                await UpdateMomData();
                _momTransitioning = false;
            }
        }
        catch (ObjectDisposedException) { }
        catch (Microsoft.JSInterop.JSDisconnectedException) { }
    }

    private async Task SetPeriod(string period)
    {
        if (_disposed) return;
        _selectedPeriod = period;
        try
        {
            // Synthetic chart needs SetData (rebase changes all values).
            // Rolling/vol just need their visible range moved — data is already loaded in full.
            await UpdateChartData();

            // Batch-adjust visible range for rolling + volatility in a single JS call.
            var rangeEntries = new List<object>();
            if (_rollReady)
            {
                var (from, to) = GetVisibleRange(_rollMinTime, _rollMaxTime);
                rangeEntries.Add(new { timeScale = _rollTimeScaleRef!, from = (long?)from, to = (long?)to });
            }
            if (_volReady)
            {
                var (from, to) = GetVisibleRange(_volMinTime, _volMaxTime);
                rangeEntries.Add(new { timeScale = _volTimeScaleRef!, from = (long?)from, to = (long?)to });
            }
            if (rangeEntries.Count > 0)
                await _jsModule!.InvokeVoidAsync("batchSetVisibleRange", rangeEntries);
        }
        catch (ObjectDisposedException) { }
        catch (Microsoft.JSInterop.JSDisconnectedException) { }
    }

    // ── Crosshair handlers ──

    private void OnMainCrosshair(object? sender, LightweightCharts.Blazor.Models.Events.MouseEventParams<long> e)
        => HandleCrosshair(e, ref _lastHoverTime, _chartContainer);

    private void OnRollCrosshair(object? sender, LightweightCharts.Blazor.Models.Events.MouseEventParams<long> e)
        => HandleCrosshair(e, ref _rollLastHover, _rollContainer);

    private void OnVolCrosshair(object? sender, LightweightCharts.Blazor.Models.Events.MouseEventParams<long> e)
        => HandleCrosshair(e, ref _volLastHover, _volContainer);

    private void OnMomCrosshair(object? sender, LightweightCharts.Blazor.Models.Events.MouseEventParams<long> e)
        => HandleCrosshair(e, ref _momLastHover, _momContainer);

    // Crosshair events fire from JS on a non-UI thread. Fire-and-forget (_ = InvokeAsync)
    // is intentional — awaiting would block the event pipeline. _disposed guard prevents
    // JS calls after the component starts tearing down.
    private void HandleCrosshair(LightweightCharts.Blazor.Models.Events.MouseEventParams<long> e,
        ref long? lastHover, ElementReference container)
    {
        if (_disposed) return;
        try
        {
            if (e.Time is null)
            {
                if (lastHover is not null)
                {
                    lastHover = null;
                    _ = InvokeAsync(() => _jsModule?.InvokeVoidAsync("hideTooltip", container));
                }
                return;
            }
            if (e.Time == lastHover) return;
            lastHover = e.Time;
            if (e.Point is not null)
                _ = InvokeAsync(() => _jsModule?.InvokeVoidAsync("showTooltip", container, e.Point.X, e.Point.Y, e.Time.Value));
        }
        catch (ObjectDisposedException) { }
        catch (Microsoft.JSInterop.JSDisconnectedException) { }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_clockTimer is not null)
        {
            // Stop the timer before disposing — prevents callbacks firing during teardown
            _clockTimer.Change(Timeout.Infinite, Timeout.Infinite);
            await _clockTimer.DisposeAsync();
        }

        // Unsubscribe crosshair events before chart components dispose themselves
        if (_chartRef is not null) _chartRef.CrosshairMoved -= OnMainCrosshair;
        if (_rollRef is not null) _rollRef.CrosshairMoved -= OnRollCrosshair;
        if (_volRef is not null) _volRef.CrosshairMoved -= OnVolCrosshair;
        if (_momRef is not null) _momRef.CrosshairMoved -= OnMomCrosshair;

        if (_jsModule is not null)
        {
            try
            {
                // Destroy Chart.js instances to free canvas memory.
                // JSDisconnectedException is expected when the circuit is already gone (e.g. tab close).
                if (_radarReady) await _jsModule.InvokeVoidAsync("destroyRadarChart");
                if (_donutReady) await _jsModule.InvokeVoidAsync("destroyDonutChart");
                await _jsModule.DisposeAsync();
            }
            catch (Microsoft.JSInterop.JSDisconnectedException) { }
        }
    }

