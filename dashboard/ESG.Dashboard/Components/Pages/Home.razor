    private static string ScoreBarWidth(double? score, IEnumerable<double?> allScores)
    {
        var vals = allScores.Where(s => s.HasValue).Select(s => s!.Value).ToList();
        if (!score.HasValue || vals.Count == 0) return "0%";
        var min = vals.Min();
        var max = vals.Max();
        if (Math.Abs(max - min) < 0.001) return "50%";
        return $"{(score.Value - min) / (max - min) * 100:F0}%";
    }

    private static string UpsideBarWidth(double? upside, IEnumerable<double?> allUpsides)
    {
        var vals = allUpsides.Where(u => u.HasValue).Select(u => Math.Abs(u!.Value)).ToList();
        if (!upside.HasValue || vals.Count == 0) return "0%";
        var maxAbs = vals.Max();
        if (maxAbs < 0.001) return "0%";
        return $"{Math.Abs(upside.Value) / maxAbs * 100:F0}%";
    }

