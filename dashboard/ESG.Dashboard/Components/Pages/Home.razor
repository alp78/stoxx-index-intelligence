@* ───────────────────────────────────────────────────────────────────
   Home / Overview — single-index dashboard with charts and signals.
   Layout: exchange clocks → index selector → snapshot strip →
   50/50 grid (line charts | radar + donut) → daily/quarterly signals.
   ─────────────────────────────────────────────────────────────────── *@
@page "/"
@rendermode InteractiveServer
@inject IndexPerformanceRepository PerfRepo
@inject ScoresRepository ScoresRepo
@inject StockRepository StockRepo
@inject IJSRuntime JS
@inject IndexSelectionState IdxState
@inject CountryFlags Flags
@inject IndexRegistry IdxReg
@implements IAsyncDisposable
@using LightweightCharts.Blazor.Charts
@using LightweightCharts.Blazor.Customization
@using LightweightCharts.Blazor.Customization.Chart
@using LightweightCharts.Blazor.Customization.Series
@using LightweightCharts.Blazor.Customization.Enums
@using LightweightCharts.Blazor.DataItems
@using LightweightCharts.Blazor.Models
@using LightweightCharts.Blazor.Series

<PageTitle>STOXX Index Intelligence</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <!-- Exchange clocks — live local time for major exchanges, green dot when market is open -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; padding: 4px 0;">
        @foreach (var ex in _exchanges)
        {
            var now = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, ex.Tz);
            var open = IsMarketOpen(now, ex);
            <div style="display: flex; align-items: center; gap: 8px; flex: 1; justify-content: center;">
                <span style="width: 6px; height: 6px; border-radius: 50%; background: @(open ? "#26A69A" : "#444"); flex-shrink: 0;"></span>
                <div style="line-height: 1.1;">
                    <span style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px; color: @(open ? "#E0E0E0" : "#666");">@ex.Symbol</span>
                    <div style="font-size: 0.6rem; opacity: 0.4;">@ex.City</div>
                </div>
                <span style="font-size: 0.85rem; font-weight: 500; font-family: 'Inter', monospace; color: @(open ? "#E0E0E0" : "#555");">@now.ToString("HH:mm")</span>
                @if (open)
                {
                    <span style="font-size: 0.55rem; text-transform: uppercase; letter-spacing: 1px; color: #26A69A; font-weight: 600;">open</span>
                }
            </div>
        }
    </div>

    <!-- Index selector — switching drives all charts, signals, and composition views via OnSignalIndexChanged -->
    <div class="d-flex align-center mb-3" style="gap: 12px;">
        <MudSelect T="string" Value="_selectedSignalIndex" ValueChanged="OnSignalIndexChanged"
                   Variant="Variant.Outlined" Dense="true" Style="max-width: 300px;" Margin="Margin.Dense">
            @foreach (var idx in _indexKeys)
            {
                <MudSelectItem Value="@idx">@FormatIndexName(idx)</MudSelectItem>
            }
        </MudSelect>
    </div>

    <!-- Index snapshot strip — cap-weighted aggregate metrics (YTD, rolling returns, vol, valuation) -->
    @if (SelectedSnap is not null)
    {
        <div class="mb-2">
            <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                <ChildContent>
                    <MudText Typo="Typo.subtitle2" Style="opacity: 0.35; cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.2);">INDEX SNAPSHOT</MudText>
                </ChildContent>
                <TooltipContent>
                    <div style="@_tipStyle">
                        <div style="@_tipHead">Index Performance Snapshot</div>
                        <div style="@_tipDesc">Cap-weighted aggregate metrics for the selected index:</div>
                        <ul style="@_tipList">
                            <li><b>YTD</b> &mdash; year-to-date cumulative return</li>
                            <li><b>30d / 90d Ret</b> &mdash; rolling 30- and 90-day returns</li>
                            <li><b>30d Vol</b> &mdash; 30-day annualized volatility</li>
                            <li><b>PE / PB</b> &mdash; average price-to-earnings and price-to-book</li>
                            <li><b>Yield</b> &mdash; average dividend yield</li>
                        </ul>
                    </div>
                </TooltipContent>
            </MudTooltip>
            <MudText Typo="Typo.caption" Style="display: block; opacity: 0.3; font-size: 0.65rem;">Updated @SelectedSnap.PerfDate.ToString("yyyy-MM-dd") &middot; @SelectedSnap.StocksCount stocks</MudText>
        </div>
        <MudPaper Class="pa-2 px-3 mb-3" Elevation="1">
            <div style="display: flex; align-items: center; justify-content: space-between; font-size: 0.75rem; flex-wrap: wrap; gap: 4px 0;">
                <span><span style="opacity: 0.4;">YTD</span> <span style="font-weight: 600; color: @ReturnHex(SelectedSnap.YtdReturn);">@FormatPct(SelectedSnap.YtdReturn)</span></span>
                <span style="opacity: 0.3;">|</span>
                <span><span style="opacity: 0.4;">30d Ret</span> <span style="font-weight: 600; color: @ReturnHex(SelectedSnap.Rolling30dReturn);">@FormatPct(SelectedSnap.Rolling30dReturn)</span></span>
                <span style="opacity: 0.3;">|</span>
                <span><span style="opacity: 0.4;">90d Ret</span> <span style="font-weight: 600; color: @ReturnHex(SelectedSnap.Rolling90dReturn);">@FormatPct(SelectedSnap.Rolling90dReturn)</span></span>
                <span style="opacity: 0.3;">|</span>
                <span><span style="opacity: 0.4;">30d Vol</span> <span style="font-weight: 600;">@FormatPct(SelectedSnap.Rolling30dVolatility)</span></span>
                <span style="opacity: 0.3;">|</span>
                <span><span style="opacity: 0.4;">PE</span> @FormatNum(SelectedSnap.AvgPe)</span>
                <span style="opacity: 0.3;">|</span>
                <span><span style="opacity: 0.4;">PB</span> @FormatNum(SelectedSnap.AvgPb)</span>
                <span style="opacity: 0.3;">|</span>
                <span><span style="opacity: 0.4;">Yield</span> @FormatPct(SelectedSnap.AvgDividendYield)</span>
            </div>
        </MudPaper>
    }

    <!-- Charts: 50/50 split — left: 3 LightweightCharts stacked, right: Chart.js radar + donut.
         Left charts use LightweightCharts Blazor wrapper; right charts use vanilla Chart.js via JS module. -->
    <MudGrid Spacing="3" Class="mb-4" Style="align-items: stretch;">
        <MudItem xs="12" md="6" Style="display: flex; flex-direction: column;">
            <!-- Rolling 30d Return — period buttons re-filter pre-loaded data, no DB call needed -->
            <MudPaper Class="pa-3 mb-3" Elevation="2">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                    <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                        <ChildContent>
                            <MudText Typo="Typo.caption" Style="opacity: 0.4; cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.2);">Rolling 30d Return (%)</MudText>
                        </ChildContent>
                        <TooltipContent>
                            <div style="@_tipStyle">
                                <div style="@_tipHead">Rolling 30-Day Return</div>
                                <div style="@_tipDesc">Trailing 30-day cumulative return for each index, recalculated daily.</div>
                                <ul style="@_tipList">
                                    <li>Rising lines signal recent strength</li>
                                    <li>Divergence between indices highlights relative outperformance</li>
                                    <li>Use period buttons to compare across different time horizons</li>
                                </ul>
                                <div style="@_tipNote">Each line represents one index — compare slopes to spot rotation between regions.</div>
                            </div>
                        </TooltipContent>
                    </MudTooltip>
                    <MudButtonGroup OverrideStyles="false" Size="Size.Small">
                        @foreach (var p in _periods)
                        {
                            var period = p;
                            <MudButton Variant="@(_selectedPeriod == period.Key ? Variant.Filled : Variant.Text)"
                                       Color="MudBlazor.Color.Default"
                                       Style="min-width: 32px; padding: 2px 6px; font-size: 0.7rem;"
                                       OnClick="@(() => SetPeriod(period.Key))">@period.Key</MudButton>
                        }
                    </MudButtonGroup>
                </div>
                <div @ref="_rollContainer" style="position: relative; height: 200px; overflow: hidden; background: #1E1E2D; opacity: @(_rollReady ? "1" : "0"); transition: opacity 0.15s ease-in;">
                    <ChartShell @ref="_rollShell" />
                    <div class="chart-tooltip"></div>
                </div>
            </MudPaper>

            <!-- Synthetic portfolio return — cumulative return rebased to 0% at period start -->
            <MudPaper Class="pa-3 mb-3" Elevation="2">
                <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                    <ChildContent>
                        <MudText Typo="Typo.caption" Style="opacity: 0.4; cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.2);" Class="mb-1">Synthetic portfolio return (%)</MudText>
                    </ChildContent>
                    <TooltipContent>
                        <div style="@_tipStyle">
                            <div style="@_tipHead">Synthetic Portfolio Return</div>
                            <div style="@_tipDesc">Cumulative return of an equal-weight portfolio holding all index constituents, rebased to 0% at period start.</div>
                            <ul style="@_tipList">
                                <li>Simulates a naive buy-and-hold across each universe</li>
                                <li>Positive slope = portfolio gaining value</li>
                                <li>Compare lines to see which region performed best</li>
                            </ul>
                        </div>
                    </TooltipContent>
                </MudTooltip>
                <div @ref="_chartContainer" style="position: relative; height: 160px; overflow: hidden; background: #1E1E2D; opacity: @(_chartReady ? "1" : "0"); transition: opacity 0.15s ease-in;">
                    <ChartShell @ref="_chartShell" />
                    <div class="chart-tooltip"></div>
                </div>
            </MudPaper>

            <!-- 30d Annualized Volatility — stddev * sqrt(252), color-banded thresholds in tooltip -->
            <MudPaper Class="pa-3" Elevation="2" Style="flex: 1;">
                <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                    <ChildContent>
                        <MudText Typo="Typo.caption" Style="opacity: 0.4; cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.2);" Class="mb-1">30d Annualized Volatility (%)</MudText>
                    </ChildContent>
                    <TooltipContent>
                        <div style="@_tipStyle">
                            <div style="@_tipHead">30-Day Annualized Volatility</div>
                            <div style="@_tipDesc">Std deviation of daily returns over 30 trading days, annualized (&times; &radic;252).</div>
                            <ul style="@_tipColorList">
                                <li><span style="color: #26A69A;">&lt; 15%</span> &mdash; low volatility, calm market</li>
                                <li><span style="color: #FFA726;">15–25%</span> &mdash; moderate uncertainty</li>
                                <li><span style="color: #EF5350;">&gt; 25%</span> &mdash; high volatility, risk elevated</li>
                            </ul>
                            <div style="@_tipNote">Spikes often precede or accompany drawdowns. Compare across indices to gauge relative risk.</div>
                        </div>
                    </TooltipContent>
                </MudTooltip>
                <div @ref="_volContainer" style="position: relative; height: 160px; overflow: hidden; background: #1E1E2D; opacity: @(_volReady ? "1" : "0"); transition: opacity 0.15s ease-in;">
                    <ChartShell @ref="_volShell" />
                    <div class="chart-tooltip"></div>
                </div>
            </MudPaper>
        </MudItem>

        <!-- Right column: Radar + Donut — rendered via Chart.js, initialized with retry
             because canvas elements may not be in the DOM on first OnAfterRenderAsync -->
        <MudItem xs="12" md="6" Style="display: flex; flex-direction: column;">
            <div class="chart-split-col">
                <MudPaper Class="pa-3 mb-3" Elevation="2">
                    <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                        <ChildContent>
                            <MudText Typo="Typo.caption" Style="opacity: 0.4; cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.2);" Class="mb-1">Factor Profile</MudText>
                        </ChildContent>
                        <TooltipContent>
                            <div style="@_tipStyle">
                                <div style="@_tipHead">Factor Profile</div>
                                <div style="@_tipDesc">Radar chart showing average z-scores across the index on five dimensions, normalized to 0&ndash;100:</div>
                                <ul style="@_tipList">
                                    <li><b>Value</b> &mdash; relative cheapness (P/E, P/B, EV/EBITDA, Yield)</li>
                                    <li><b>Momentum</b> &mdash; price trend strength (RS, SMA ratios, 52w high)</li>
                                    <li><b>Sentiment</b> &mdash; analyst consensus (upside, recommendations)</li>
                                    <li><b>Quality</b> &mdash; fundamental strength (margins, ROE, FCF)</li>
                                    <li><b>Governance</b> &mdash; corporate risk (audit, board, compensation)</li>
                                </ul>
                                <div style="@_tipNote">Larger filled area = stronger index profile. Compare across indices to spot factor tilts.</div>
                            </div>
                        </TooltipContent>
                    </MudTooltip>
                    <div style="position: relative;">
                        <canvas id="radarChart"></canvas>
                    </div>
                </MudPaper>
                <MudPaper Class="pa-3" Elevation="2">
                    <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                        <ChildContent>
                            <MudText Typo="Typo.caption" Style="opacity: 0.4; cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.2);" Class="mb-1">Index Composition</MudText>
                        </ChildContent>
                        <TooltipContent>
                            <div style="@_tipStyle">
                                <div style="@_tipHead">Index Composition</div>
                                <div style="@_tipDesc">Dual-ring donut showing how the index is constructed:</div>
                                <ul style="@_tipList">
                                    <li><b>Outer ring</b> &mdash; individual stock weights (cap-weighted)</li>
                                    <li><b>Inner ring</b> &mdash; sector allocation (aggregated weights)</li>
                                </ul>
                                <div style="@_tipNote">Hover over a segment to see the stock or sector name and its weight in the center.</div>
                            </div>
                        </TooltipContent>
                    </MudTooltip>
                    <div style="position: relative;">
                        <canvas id="donutChart"></canvas>
                    </div>
                </MudPaper>
            </div>
        </MudItem>
    </MudGrid>

    <!-- Signal tables: daily scores (2/3 width) and quarterly scores (1/3 width) -->
    <MudGrid Style="margin-top: 12px;">
        <!-- Daily Signals — refreshed daily from cross-sectional z-scores across index constituents -->
        <MudItem xs="12" lg="8">
            <MudText Typo="Typo.subtitle2" Style="opacity: 0.35; margin-bottom: 4px;">DAILY SIGNALS</MudText>
            <MudGrid>
                <!-- Row 1: Momentum + Divergence -->
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 4px;">
                            <div>
                                <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                                    <ChildContent>
                                        <MudText Typo="Typo.h6" Style="margin: 0; cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.2);">Strongest Momentum</MudText>
                                    </ChildContent>
                                    <TooltipContent>
                                        <div style="@_tipStyle">
                                            <div style="@_tipHead">Momentum Score</div>
                                            <div style="@_tipDesc">Composite of cross-sectional z-scores, averaged across four dimensions:</div>
                                            <ul style="@_tipList">
                                                <li><b>Relative Strength</b> &mdash; 6-month return vs index</li>
                                                <li><b>SMA-50 Ratio</b> &mdash; price / 50-day moving average</li>
                                                <li><b>SMA-200 Ratio</b> &mdash; price / 200-day moving average</li>
                                                <li><b>52-Week High Proximity</b> &mdash; distance from peak</li>
                                            </ul>
                                            <div style="@_tipNote">Higher score = sustained uptrend across all dimensions. Rank #1 is the strongest in the index.</div>
                                        </div>
                                    </TooltipContent>
                                </MudTooltip>
                                <MudText Typo="Typo.caption" Style="display: block; opacity: 0.3; font-size: 0.65rem;">@DailyAsOf</MudText>
                            </div>
                            <MudButtonGroup OverrideStyles="false" Size="Size.Small">
                                @foreach (var p in _momPeriods)
                                {
                                    var period = p;
                                    <MudButton Variant="@(_selectedMomPeriod == period.Key ? Variant.Filled : Variant.Text)"
                                               Color="MudBlazor.Color.Default"
                                               Style="min-width: 32px; padding: 2px 6px; font-size: 0.7rem;"
                                               OnClick="@(() => SetMomPeriod(period.Key))">@period.Key</MudButton>
                                }
                            </MudButtonGroup>
                        </div>
                        <MudText Typo="Typo.caption" Style="opacity: 0.4;" Class="mb-2">Normalized close — top 5</MudText>
                        <div style="display: flex; gap: 12px; margin-bottom: 6px; flex-wrap: wrap;">
                            @{ var momTop5 = TopMomentum.Take(5).ToList(); }
                            @for (var i = 0; i < momTop5.Count; i++)
                            {
                                <div style="display: flex; align-items: center; gap: 4px;">
                                    <span style="display: inline-block; width: 10px; height: 3px; background: @MomSeriesColors[i]; border-radius: 1px;"></span>
                                    <span style="font-size: 0.7rem; opacity: 0.6;">@momTop5[i].Symbol</span>
                                </div>
                            }
                        </div>
                        <div @ref="_momContainer" style="position: relative; height: 160px; overflow: hidden; background: #1E1E2D; opacity: @(_momReady && !_momTransitioning ? "1" : "0"); transition: opacity 0.15s ease-in;">
                            <ChartShell @ref="_momShell" />
                            <div class="chart-tooltip"></div>
                        </div>
                        <MudSimpleTable Dense="true" Hover="true" Class="mt-2 compact-table">
                            <thead><tr><th>#</th><th></th><th>Symbol</th><th>Score</th><th style="width: 80px;"></th></tr></thead>
                            <tbody>
                                @foreach (var s in TopMomentum.Take(5))
                                {
                                    <tr>
                                        <td>@s.MomentumRank</td>
                                        <td style="padding: 0 2px;"><img src="logos/@(s.Index)/@(s.Symbol).png" style="width: 18px; height: 18px; border-radius: 50%; object-fit: cover; vertical-align: middle;" onerror="this.style.display='none'" /></td>
                                        <td>
                                            @{ var si = LookupStock(s.Index, s.Symbol); }
                                            <MudTooltip Arrow="true" Placement="Placement.Right" Color="Color.Dark">
                                                <TooltipContent>
                                                    <div style="text-align: left; font-size: 0.8rem; line-height: 1.5; padding: 2px 0;">
                                                        @if (si is not null)
                                                        {
                                                            <div class="d-flex align-center" style="gap: 6px; margin-bottom: 4px;">
                                                                <img src="logos/@(s.Index)/@(s.Symbol).png" style="width: 20px; height: 20px; border-radius: 50%; object-fit: cover;" onerror="this.style.display='none'" />
                                                                <strong>@(si.ShortName ?? s.Symbol)</strong>
                                                            </div>
                                                            @if (si.Country is not null || si.City is not null)
                                                            {
                                                                <div style="opacity: 0.85;">
                                                                    @if (si.Country is not null) { <span class="fi fi-@Flags.GetCode(si.Country)" style="margin-right: 4px;"></span> }
                                                                    @(si.City is not null ? $"{si.City}, " : "")@(si.Country ?? "")
                                                                </div>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <strong>@s.Symbol</strong>
                                                        }
                                                    </div>
                                                </TooltipContent>
                                                <ChildContent><MudLink Href="@StockLink(s)">@s.Symbol</MudLink></ChildContent>
                                            </MudTooltip>
                                        </td>
                                        <td>@F(s.MomentumScore)</td>
                                        <td><span class="score-bar" style="width: @ScoreBarWidth(s.MomentumScore, TopMomentum.Select(x => x.MomentumScore)); background: #26A69A;"></span></td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                        <div class="mb-2">
                            <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                                <ChildContent>
                                    <MudText Typo="Typo.h6" Class="mb-0" Style="cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.2);">Divergence Alerts</MudText>
                                </ChildContent>
                                <TooltipContent>
                                    <div style="@_tipStyle">
                                        <div style="@_tipHead">Price vs Analyst Divergence</div>
                                        <div style="@_tipDesc">Stocks where market action conflicts with analyst consensus:</div>
                                        <ul style="@_tipColorList">
                                            <li><span style="color: #EF5350;">&#9660;</span> Price falling (negative short-term return)</li>
                                            <li><span style="color: #26A69A;">&#9650;</span> Analysts bullish (rec &le; 2.5, positive upside)</li>
                                        </ul>
                                        <div style="margin: 6px 0 4px; font-size: 0.7rem; opacity: 0.5;">Columns:</div>
                                        <ul style="@_tipList">
                                            <li><b>Upside</b> &mdash; analyst target vs current price</li>
                                            <li><b>Rec</b> &mdash; consensus (closer to <span style="color: #26A69A;">1.0</span> = stronger buy)</li>
                                        </ul>
                                        <div style="@_tipNote">Contrarian signal — price is dropping but analysts still rate it a buy with significant upside. Either the market is overreacting (opportunity) or analysts haven't caught up yet (value trap). Check fundamentals before acting.</div>
                                    </div>
                                </TooltipContent>
                            </MudTooltip>
                            <MudText Typo="Typo.caption" Style="display: block; opacity: 0.3; font-size: 0.65rem;">@DailyAsOf</MudText>
                        </div>
                        @if (DivergenceAlerts.Any())
                        {
                            <MudSimpleTable Dense="true" Hover="true" Class="compact-table">
                                <thead><tr><th></th><th>Symbol</th><th></th><th>Upside</th><th>Rec</th></tr></thead>
                                <tbody>
                                    @foreach (var s in DivergenceAlerts)
                                    {
                                        <tr>
                                            <td style="padding: 0 2px;"><img src="logos/@(s.Index)/@(s.Symbol).png" style="width: 18px; height: 18px; border-radius: 50%; object-fit: cover; vertical-align: middle;" onerror="this.style.display='none'" /></td>
                                            <td>
                                            @{ var si = LookupStock(s.Index, s.Symbol); }
                                            <MudTooltip Arrow="true" Placement="Placement.Right" Color="Color.Dark">
                                                <TooltipContent>
                                                    <div style="text-align: left; font-size: 0.8rem; line-height: 1.5; padding: 2px 0;">
                                                        @if (si is not null)
                                                        {
                                                            <div class="d-flex align-center" style="gap: 6px; margin-bottom: 4px;">
                                                                <img src="logos/@(s.Index)/@(s.Symbol).png" style="width: 20px; height: 20px; border-radius: 50%; object-fit: cover;" onerror="this.style.display='none'" />
                                                                <strong>@(si.ShortName ?? s.Symbol)</strong>
                                                            </div>
                                                            @if (si.Country is not null || si.City is not null)
                                                            {
                                                                <div style="opacity: 0.85;">
                                                                    @if (si.Country is not null) { <span class="fi fi-@Flags.GetCode(si.Country)" style="margin-right: 4px;"></span> }
                                                                    @(si.City is not null ? $"{si.City}, " : "")@(si.Country ?? "")
                                                                </div>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <strong>@s.Symbol</strong>
                                                        }
                                                    </div>
                                                </TooltipContent>
                                                <ChildContent><MudLink Href="@StockLink(s)">@s.Symbol</MudLink></ChildContent>
                                            </MudTooltip>
                                        </td>
                                            <td>
                                                <span style="color: #EF5350; font-size: 0.75rem; font-weight: 600;">&#9660;</span>
                                                <span style="color: #26A69A; font-size: 0.75rem; font-weight: 600;">&#9650;</span>
                                            </td>
                                            <td style="color: @ReturnHex(s.ImpliedUpside);">@Pct(s.ImpliedUpside)</td>
                                            <td>@F(s.RecommendationMean)</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Style="opacity: 0.5;">No divergence signals</MudText>
                        }
                    </MudPaper>
                </MudItem>

                <!-- Row 2: Value + Sentiment -->
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                        <div class="mb-2">
                            <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                                <ChildContent>
