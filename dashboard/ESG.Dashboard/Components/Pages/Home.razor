                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                        <div class="mb-2">
                            <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                                <ChildContent>
                                    <MudText Typo="Typo.h6" Class="mb-0" Style="cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.2);">Most Bullish Sentiment</MudText>
                                </ChildContent>
