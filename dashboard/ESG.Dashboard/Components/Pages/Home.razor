                                    <td>
                                            @{ var si = LookupStock(s.Index, s.Symbol); }
                                            <MudTooltip Arrow="true" Placement="Placement.Right" Color="Color.Dark">
                                                <TooltipContent>
                                                    <div style="text-align: left; font-size: 0.8rem; line-height: 1.5; padding: 2px 0;">
                                                        @if (si is not null)
                                                        {
                                                            <div class="d-flex align-center" style="gap: 6px; margin-bottom: 4px;">
                                                                <img src="logos/@(s.Index)/@(s.Symbol).png" style="width: 20px; height: 20px; border-radius: 50%; object-fit: cover;" onerror="this.style.display='none'" />
                                                                <strong>@(si.ShortName ?? s.Symbol)</strong>
                                                            </div>
                                                            @if (si.Country is not null || si.City is not null)
                                                            {
                                                                <div style="opacity: 0.85;">
                                                                    @if (si.Country is not null) { <span class="fi fi-@Flags.GetCode(si.Country)" style="margin-right: 4px;"></span> }
                                                                    @(si.City is not null ? $"{si.City}, " : "")@(si.Country ?? "")
                                                                </div>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <strong>@s.Symbol</strong>
                                                        }
                                                    </div>
                                                </TooltipContent>
                                                <ChildContent><MudLink Href="@QuarterlyStockLink(s)">@s.Symbol</MudLink></ChildContent>
                                            </MudTooltip>
                                        </td>
                                    <td>@F(s.QualityScore)</td>
                                    <td><span class="score-bar" style="width: @ScoreBarWidth(s.QualityScore, TopQuality.Select(x => x.QualityScore)); background: #26A69A;"></span></td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>

                <!-- Health Warnings -->
                <MudPaper Class="pa-4" Elevation="2">
                    <div class="mb-2">
                        <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                            <ChildContent>
                                <MudText Typo="Typo.h6" Class="mb-0" Style="cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.2);">Health Warnings</MudText>
                            </ChildContent>
                            <TooltipContent>
                                <div style="@_tipStyle">
                                    <div style="@_tipHead">Financial Health Flags</div>
                                    <div style="@_tipDesc">Stocks with 2+ flags from quarterly balance sheet data:</div>
                                    <ul style="@_tipColorList">
                                        <li><span style="color: #42A5F5;">&#9679;</span> <b>Liq</b> &mdash; current ratio &lt; 1 (liquidity risk)</li>
                                        <li><span style="color: #FFA726;">&#9679;</span> <b>Lev</b> &mdash; debt-to-equity &gt; 200% (high leverage)</li>
                                        <li><span style="color: #EF5350;">&#9679;</span> <b>Cash</b> &mdash; negative free cash flow (cash burn)</li>
                                        <li><span style="color: #AB47BC;">&#9679;</span> <b>Decl</b> &mdash; revenue &amp; margin both declining QoQ</li>
                                    </ul>
                                    <div style="margin: 6px 0 4px; font-size: 0.7rem; opacity: 0.5;">Risk levels:</div>
                                    <ul style="@_tipColorList">
                                        <li><span style="color: #42A5F5;">0 flags</span> = healthy &bull; <span style="color: #2196F3;">1</span> = watch &bull; <span style="color: #FFA726;">2</span> = warning &bull; <span style="color: #EF5350;">3+</span> = critical</li>
                                    </ul>
                                    <div style="@_tipNote">Low quality score + many flags = strong caution signal.</div>
                                </div>
                            </TooltipContent>
                        </MudTooltip>
                        <MudText Typo="Typo.caption" Style="display: block; opacity: 0.3; font-size: 0.65rem;">@QuarterlyAsOf</MudText>
                    </div>
                    <div style="display: flex; gap: 8px; font-size: 0.6rem; opacity: 0.5; margin-bottom: 4px;">
                        <span><span class="flag-dot" style="background: #42A5F5;"></span>Liq</span>
                        <span><span class="flag-dot" style="background: #FFA726;"></span>Lev</span>
                        <span><span class="flag-dot" style="background: #EF5350;"></span>Cash</span>
                        <span><span class="flag-dot" style="background: #AB47BC;"></span>Decl</span>
                    </div>
                    @if (HealthWarnings.Any())
                    {
                        <MudSimpleTable Dense="true" Hover="true" Class="compact-table">
                            <thead><tr><th></th><th>Symbol</th><th>Flags</th><th>Level</th><th>Quality</th></tr></thead>
                            <tbody>
                                @foreach (var s in HealthWarnings)
                                {
                                    <tr>
                                        <td style="padding: 0 2px;"><img src="logos/@(s.Index)/@(s.Symbol).png" style="width: 18px; height: 18px; border-radius: 50%; object-fit: cover; vertical-align: middle;" onerror="this.style.display='none'" /></td>
                                        <td>
                                            @{ var si = LookupStock(s.Index, s.Symbol); }
                                            <MudTooltip Arrow="true" Placement="Placement.Right" Color="Color.Dark">
                                                <TooltipContent>
                                                    <div style="text-align: left; font-size: 0.8rem; line-height: 1.5; padding: 2px 0;">
                                                        @if (si is not null)
                                                        {
                                                            <div class="d-flex align-center" style="gap: 6px; margin-bottom: 4px;">
                                                                <img src="logos/@(s.Index)/@(s.Symbol).png" style="width: 20px; height: 20px; border-radius: 50%; object-fit: cover;" onerror="this.style.display='none'" />
                                                                <strong>@(si.ShortName ?? s.Symbol)</strong>
                                                            </div>
                                                            @if (si.Country is not null || si.City is not null)
                                                            {
                                                                <div style="opacity: 0.85;">
                                                                    @if (si.Country is not null) { <span class="fi fi-@Flags.GetCode(si.Country)" style="margin-right: 4px;"></span> }
                                                                    @(si.City is not null ? $"{si.City}, " : "")@(si.Country ?? "")
                                                                </div>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <strong>@s.Symbol</strong>
                                                        }
                                                    </div>
                                                </TooltipContent>
                                                <ChildContent><MudLink Href="@QuarterlyStockLink(s)">@s.Symbol</MudLink></ChildContent>
                                            </MudTooltip>
                                        </td>
                                        <td>
                                            <span class="flag-dot" style="background: @(s.FlagLiquidity == true ? "#42A5F5" : "#333");"></span>
                                            <span class="flag-dot" style="background: @(s.FlagLeverage == true ? "#FFA726" : "#333");"></span>
                                            <span class="flag-dot" style="background: @(s.FlagCashburn == true ? "#EF5350" : "#333");"></span>
                                            <span class="flag-dot" style="background: @(s.FlagDoublDecline == true ? "#AB47BC" : "#333");"></span>
                                        </td>
                                        <td>
                                            <MudChip T="string" Size="Size.Small"
                                                     Color="@HealthColor(s.HealthRiskLevel)">
                                                @s.HealthRiskLevel
                                            </MudChip>
                                        </td>
                                        <td>@F(s.QualityScore)</td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Style="opacity: 0.5;">No warnings</MudText>
                    }
                </MudPaper>
            </div>
        </MudItem>
    </MudGrid>
}

@code {
    // ── State ──────────────────────────────────────────────────────────
    private bool _loading = true;
    private List<IndexPerformance> _snapshots = [];
    private Dictionary<string, List<IndexPerformance>> _perfByIndex = [];
    private string[] _indexKeys = [];

    // ── Exchange clocks — timer ticks every 10s to refresh displayed times ──
    private System.Threading.Timer? _clockTimer;

    private record ExchangeInfo(string Symbol, string City, TimeZoneInfo Tz, TimeSpan Open, TimeSpan Close);

    private static readonly ExchangeInfo[] _exchanges =
    [
        new("TSE", "Tokyo", TimeZoneInfo.FindSystemTimeZoneById("Tokyo Standard Time"), new(9, 0, 0), new(15, 0, 0)),
        new("HKEX", "Hong Kong", TimeZoneInfo.FindSystemTimeZoneById("China Standard Time"), new(9, 30, 0), new(16, 0, 0)),
        new("ASX", "Sydney", TimeZoneInfo.FindSystemTimeZoneById("AUS Eastern Standard Time"), new(10, 0, 0), new(16, 0, 0)),
        new("XETRA", "Frankfurt", TimeZoneInfo.FindSystemTimeZoneById("W. Europe Standard Time"), new(9, 0, 0), new(17, 30, 0)),
        new("NYSE", "New York", TimeZoneInfo.FindSystemTimeZoneById("Eastern Standard Time"), new(9, 30, 0), new(16, 0, 0)),
    ];

    private static bool IsMarketOpen(DateTime localNow, ExchangeInfo ex)
        => localNow.DayOfWeek is >= DayOfWeek.Monday and <= DayOfWeek.Friday
           && localNow.TimeOfDay >= ex.Open && localNow.TimeOfDay < ex.Close;

    // ── LightweightCharts (synthetic portfolio, rolling 30d, volatility) ──
    // Each chart uses a single series — on index switch, SetData replaces the data in-place.
    // TimeScale refs are cached at init to avoid extra JS interop round-trips on every update.
    private ChartShell? _chartShell;
    private ChartComponent? _chartRef => _chartShell?.Chart;
    private ElementReference _chartContainer;
    // Stored as { __uniqueJavascriptId: "..." } objects — passed directly to JS _resolve()
    private object? _chartJsRef;      // chart object ref (for rogue-series cleanup)
    private object? _chartSeriesRef;
    private object? _chartTimeScaleRef;
    private bool _chartReady;
    private string _selectedPeriod = "3Y";
    private IJSObjectReference? _jsModule;
    private bool _disposed;

    // Rolling 30d return chart
    private ChartShell? _rollShell;
    private ChartComponent? _rollRef => _rollShell?.Chart;
    private ElementReference _rollContainer;
    private object? _rollJsRef;
    private object? _rollSeriesRef;
    private object? _rollTimeScaleRef;
    private bool _rollReady;

    // Volatility chart
    private ChartShell? _volShell;
    private ChartComponent? _volRef => _volShell?.Chart;
    private ElementReference _volContainer;
    private object? _volJsRef;
    private object? _volSeriesRef;
    private object? _volTimeScaleRef;
    private bool _volReady;

    // Tooltip state
    private Dictionary<long, (DateTime Date, Dictionary<string, double> Values)> _tsLookup = new();
    private Dictionary<long, (DateTime Date, Dictionary<string, double> Values)> _rollLookup = new();
    private Dictionary<long, (DateTime Date, Dictionary<string, double> Values)> _volLookup = new();
    private long? _lastHoverTime;
    private long? _rollLastHover;
    private long? _volLastHover;

    // ── Signals (daily + quarterly scores) ──────────────────────────
    private string _selectedSignalIndex = null!;
    private List<ScoreDaily> _daily = [];
    private List<ScoreQuarterly> _quarterly = [];
    private Dictionary<(string Index, string Symbol), StockInfo> _stockLookup = new();

    // ── Chart.js (radar factor profile, donut composition) ──────────
    // Init returns false if the canvas isn't in the DOM yet; _chartInitRetries caps retry attempts.
    private bool _radarReady;
    private bool _donutReady;
    private int _chartInitRetries;

    // Momentum sparkline chart
    private ChartShell? _momShell;
    private ChartComponent? _momRef => _momShell?.Chart;
    private ElementReference _momContainer;
    private bool _momReady;
    private bool _momTransitioning;
    private Dictionary<string, List<SymbolClose>> _momClosesData = new();
    private ISeriesApi<long>?[] _momSeriesRefs = new ISeriesApi<long>?[5];
    private Dictionary<long, (DateTime Date, Dictionary<string, double> Values)> _momLookup = new();
    private long? _momLastHover;

    private static readonly string[] MomSeriesColors = ["#42A5F5", "#26A69A", "#AB47BC", "#FFA726", "#EF5350"];
    private string _selectedMomPeriod = "1M";

    private static readonly (string Key, Func<DateTime, DateTime?> GetStart)[] _momPeriods =
    [
        ("1M", now => now.AddMonths(-1)),
        ("3M", now => now.AddMonths(-3)),
        ("6M", now => now.AddMonths(-6)),
        ("1Y", now => now.AddYears(-1)),
    ];

    private IndexPerformance? SelectedSnap => _snapshots.FirstOrDefault(s => s.Index == _selectedSignalIndex);

    private string DailyAsOf => _daily
        .Where(d => d.Index == _selectedSignalIndex)
        .Select(d => d.ScoreDate).DefaultIfEmpty()
        .Max() is var dt && dt != default ? $"Updated {dt:yyyy-MM-dd}" : "";

    private string QuarterlyAsOf => _quarterly
        .Where(q => q.Index == _selectedSignalIndex)
        .Select(q => q.AsOfDate).DefaultIfEmpty()
        .Max() is var dt && dt != default ? $"Updated {dt:yyyy-MM-dd}" : "";

    private IEnumerable<ScoreDaily> TopValue => _daily
        .Where(d => d.Index == _selectedSignalIndex)
        .OrderBy(d => d.RelativeValueRank).Take(10);

    private IEnumerable<ScoreDaily> TopMomentum => _daily
        .Where(d => d.Index == _selectedSignalIndex)
        .OrderBy(d => d.MomentumRank).Take(10);

    private IEnumerable<ScoreDaily> TopSentiment => _daily
        .Where(d => d.Index == _selectedSignalIndex)
        .OrderBy(d => d.SentimentRank).Take(10);

    private IEnumerable<ScoreDaily> DivergenceAlerts => _daily
        .Where(d => d.Index == _selectedSignalIndex && d.PriceFallingAnalystsBullish == true)
        .OrderByDescending(d => d.ImpliedUpside);

    private IEnumerable<ScoreQuarterly> HealthWarnings => _quarterly
        .Where(q => q.Index == _selectedSignalIndex && q.HealthFlagsCount >= 2)
        .OrderByDescending(q => q.HealthFlagsCount);

    private IEnumerable<ScoreQuarterly> TopQuality => _quarterly
        .Where(q => q.Index == _selectedSignalIndex)
        .OrderBy(q => q.QualityRank).Take(10);

    private static readonly (string Key, Func<DateTime, DateTime?> GetStart)[] _periods =
    [
        ("1M", now => now.AddMonths(-1)),
        ("3M", now => now.AddMonths(-3)),
        ("6M", now => now.AddMonths(-6)),
        ("1Y", now => now.AddYears(-1)),
        ("3Y", now => now.AddYears(-3)),
        ("YTD", now => new DateTime(now.Year, 1, 1)),
        ("ALL", _ => null),
    ];

    private string IndexColor(string key) => IdxReg.GetColor(key);

    // ── Lifecycle ─────────────────────────────────────────────────────

    // Loads all data in parallel, then picks the remembered index (or first available).
    protected override async Task OnInitializedAsync()
    {
        var snapshotsTask = PerfRepo.GetLatestSnapshotAsync();
        var perfTask = PerfRepo.GetPerformanceAsync();
        var dailyTask = ScoresRepo.GetDailyScoresAsync();
        var quarterlyTask = ScoresRepo.GetQuarterlyScoresAsync();
        var keysTask = StockRepo.GetIndexKeysAsync();
        var stocksTask = StockRepo.GetStocksAsync();

        await Task.WhenAll(snapshotsTask, perfTask, dailyTask, quarterlyTask, keysTask, stocksTask);

        _snapshots = (await snapshotsTask).ToList();
        _daily = (await dailyTask).ToList();
        _quarterly = (await quarterlyTask).ToList();
        _stockLookup = (await stocksTask).ToDictionary(s => (s.Index, s.Symbol));

        var keys = (await keysTask).ToList();
        _selectedSignalIndex = keys.Contains(IdxState.SelectedIndex)
            ? IdxState.SelectedIndex
            : keys.FirstOrDefault() ?? "euro_stoxx_50";

        var perf = (await perfTask).ToList();
        _perfByIndex = perf
            .GroupBy(p => p.Index)
            .ToDictionary(g => g.Key, g =>
            {
                var ordered = g.OrderBy(p => p.PerfDate).ToList();
                // Trim trailing zero-return rows — stale placeholder data from the pipeline
                while (ordered.Count > 1 && Math.Abs(ordered[^1].DailyReturn ?? 0) < 0.0001)
                    ordered.RemoveAt(ordered.Count - 1);
                return ordered;
            });

        _indexKeys = keys.Count != 0 ? keys.ToArray() : _snapshots.Select(s => s.Index).OrderBy(k => k).ToArray();

        await LoadMomentumCloses();
        _loading = false;

        // _disposed guard: timer fires on a threadpool thread and can race with DisposeAsync
        _clockTimer = new System.Threading.Timer(_ =>
        {
            if (!_disposed) try { InvokeAsync(StateHasChanged); } catch (ObjectDisposedException) { }
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(10));
    }

    private DateTime? GetMomCutoff()
    {
        var p = _momPeriods.FirstOrDefault(p => p.Key == _selectedMomPeriod);
        return p.GetStart?.Invoke(DateTime.UtcNow);
    }

    // Pre-loads 3 years of close data for top-5 momentum stocks so period switches
    // (1M/3M/6M/1Y) only re-filter in memory — no additional DB calls needed.
    private async Task LoadMomentumCloses()
    {
        var indexDaily = _daily.Where(d => d.Index == _selectedSignalIndex).ToList();
        var top5 = indexDaily
            .OrderBy(d => d.MomentumRank).Take(5)
            .Select(d => d.Symbol).ToArray();
        if (top5.Length == 0) { _momClosesData.Clear(); return; }

        var latestDate = indexDaily.Max(d => d.ScoreDate);
        var from = latestDate.AddYears(-3).AddMonths(-1);
        var closes = (await StockRepo.GetBatchClosesAsync(_selectedSignalIndex, top5, from)).ToList();
        _momClosesData = closes.GroupBy(c => c.Symbol)
            .ToDictionary(g => g.Key, g => g.OrderBy(c => c.Date).ToList());
    }

    // Two-phase chart init pattern:
    //   Phase 1 — chart shell creation runs in parallel (Task.WhenAll) because each init
    //             only touches its own DOM element and doesn't conflict.
    //   Phase 2 — data push runs sequentially (await one by one) because Blazor Server
    //             funnels all JS interop through a single SignalR pipe; parallel calls
    //             deadlock the circuit.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            // Import on first render, or re-import if a prior render cycle disposed the module
            if (_jsModule is null)
            {
                _jsModule = await JS.InvokeAsync<IJSObjectReference>("import",
                    "./Components/Pages/Home.razor.js");
            }

            if (_disposed) return;

            // Batch-init line charts: wait for all ChartComponent shells to be ready,
            // then init + load data for all 3 in a SINGLE JS interop call.
            var lineChartsToInit = new List<(ChartComponent chart, string role)>();
            if (!_chartReady && _chartRef is not null) lineChartsToInit.Add((_chartRef, "chart"));
            if (!_rollReady && _rollRef is not null) lineChartsToInit.Add((_rollRef, "roll"));
            if (!_volReady && _volRef is not null) lineChartsToInit.Add((_volRef, "vol"));

            // Other charts init in parallel via wrapper (momentum uses 5 series, can't batch easily)
            var otherTasks = new List<Task>();
            if (!_momReady && _momRef is not null)
                otherTasks.Add(InitMomentumChart());
            if (!_radarReady && _jsModule is not null && _daily.Count > 0)
                otherTasks.Add(InitRadarChart());
            if (!_donutReady && _jsModule is not null && _daily.Count > 0)
                otherTasks.Add(InitDonutChart());

            if (lineChartsToInit.Count > 0 || otherTasks.Count > 0)
            {
                // Wait for all ChartComponent canvases to be ready (parallel)
                if (lineChartsToInit.Count > 0)
                    await Task.WhenAll(lineChartsToInit.Select(c => c.chart.InitializationCompleted));

                if (_disposed) return;

                // Batch-init all line charts + push data in ONE JS call
                if (lineChartsToInit.Count > 0)
                    await BatchInitLineCharts(lineChartsToInit);

                if (_disposed) return;

                // Wait for other chart inits
                if (otherTasks.Count > 0)
                    await Task.WhenAll(otherTasks);

                if (_disposed) return;

                if (!_radarReady || !_donutReady)
                    _chartInitRetries++;

                if (_momReady) await UpdateMomData();
                StateHasChanged();
            }
            else if (_jsModule is not null && (!_radarReady || !_donutReady) && _chartInitRetries < 5)
            {
                // Radar/donut canvas may not be in the DOM yet on first render — retry up to 5 times
                _chartInitRetries++;
                await Task.Delay(50);
                if (!_disposed) StateHasChanged();
            }
        }
        catch (ObjectDisposedException) { }
        catch (Microsoft.JSInterop.JSDisconnectedException) { }
        catch (TaskCanceledException) { }
    }

    // Batch-init all 3 line charts in a SINGLE JS interop call.
    // Bypasses the wrapper's per-chart ApplyOptions/AddSeries/TimeScale round-trips
    // (~9 sequential SignalR calls) by driving the LightweightCharts API directly in JS.
    private async Task BatchInitLineCharts(List<(ChartComponent chart, string role)> charts)
    {
        if (_jsModule is null || _disposed) return;

        // Subscribe crosshair events (C#-only, no interop)
        foreach (var (chart, role) in charts)
        {
            switch (role)
            {
                case "chart": chart.CrosshairMoved += OnMainCrosshair; break;
                case "roll": chart.CrosshairMoved += OnRollCrosshair; break;
                case "vol": chart.CrosshairMoved += OnVolCrosshair; break;
            }
        }

        // Prepare data for all charts
        var chartData = PrepareChartData();
        var rollData = PrepareSimpleSeriesData(_rollLookup, p => p.Rolling30dReturn, out _rollMinTime, out _rollMaxTime);
        var volData = PrepareSimpleSeriesData(_volLookup, p => p.Rolling30dVolatility, out _volMinTime, out _volMaxTime);
        var ttIndices = new[] { new { key = _selectedSignalIndex, name = FormatIndexName(_selectedSignalIndex), color = IndexColor(_selectedSignalIndex) } };

        // Build per-chart entries and tooltip entries
        var entries = new List<object>();
        var tooltips = new List<object>();
        foreach (var (chart, role) in charts)
        {
            var (data, container, colorBySign) = role switch
            {
                "chart" => (chartData, _chartContainer, true),
                "roll" => (rollData, _rollContainer, true),
                _ => (volData, _volContainer, false)
            };
            var (from, to) = role == "chart"
                ? (data.Length > 0 ? data[0].Time : 0L, data.Length > 0 ? data[^1].Time : 0L)
                : GetVisibleRange(role == "roll" ? _rollMinTime : _volMinTime, role == "roll" ? _rollMaxTime : _volMaxTime);

            entries.Add(new
            {
                chartRef = chart.JsObjectReference,
                data,
                from = data.Length > 0 ? (long?)from : null,
                to = data.Length > 0 ? (long?)to : null
            });
            tooltips.Add(new
            {
                container,
                lookup = BuildTooltipLookup(role == "chart" ? _tsLookup : role == "roll" ? _rollLookup : _volLookup),
                indices = ttIndices,
                options = new { colorBySign }
            });
        }

        // Chart options matching InitChartOptions
        var chartOptions = new
        {
            autoSize = true,
            layout = new { background = new { type = "solid", color = "#1E1E2D" }, textColor = "#A0AEC0", fontFamily = "Inter", fontSize = 11 },
            grid = new
            {
                vertLines = new { color = "rgba(255,255,255,0.06)" },
                horzLines = new { color = "rgba(255,255,255,0.06)" }
            },
            rightPriceScale = new { borderVisible = false },
            timeScale = new { borderVisible = false, fixLeftEdge = true, fixRightEdge = true, rightOffset = 0, lockVisibleTimeRangeOnResize = true },
            crosshair = new { mode = 1 }
        };
        var seriesOptions = new
        {
            color = "#FFFFFF",
            lineWidth = 1,
            crosshairMarkerVisible = false,
            lastValueVisible = false,
            priceLineVisible = false
        };

        // Single JS call: init + data + visible range + tooltips for all 3 charts.
        // Returns [{ series: { __uniqueJavascriptId }, timeScale: { __uniqueJavascriptId } }]
        var results = await _jsModule!.InvokeAsync<ChartInitResult[]>("batchInitLineCharts", entries, tooltips, chartOptions, seriesOptions);

        // Store the returned IDs as objects that _resolve() can look up in later batch calls
        for (int i = 0; i < charts.Count; i++)
        {
            var s = new { __uniqueJavascriptId = results[i].Series.__uniqueJavascriptId };
            var ts = new { __uniqueJavascriptId = results[i].TimeScale.__uniqueJavascriptId };
            var chartJsRef = charts[i].chart.JsObjectReference;
            switch (charts[i].role)
            {
                case "chart":
                    _chartJsRef = chartJsRef; _chartSeriesRef = s; _chartTimeScaleRef = ts; _chartReady = true;
                    break;
                case "roll":
                    _rollJsRef = chartJsRef; _rollSeriesRef = s; _rollTimeScaleRef = ts; _rollReady = true;
                    break;
                case "vol":
                    _volJsRef = chartJsRef; _volSeriesRef = s; _volTimeScaleRef = ts; _volReady = true;
                    break;
            }
        }
    }

    private async Task InitMomentumChart()
    {
        if (_disposed) return;
        await InitSparklineOptions(_momRef!);
        if (_disposed) return;
        _momRef!.CrosshairMoved += OnMomCrosshair;
        for (int i = 0; i < 5; i++)
        {
            _momSeriesRefs[i] = await _momRef!.AddSeries<LineStyleOptions>(
                SeriesType.Line,
                new LineStyleOptions
                {
                    Color = Clr(MomSeriesColors[i]),
                    LineWidth = 2,
                    CrosshairMarkerVisible = false,
                    LastValueVisible = false,
                    PriceLineVisible = false
                });
        }
        _momReady = true;
    }

    private async Task InitSparklineOptions(ChartComponent chart)
    {
        if (_disposed) return;
        await chart.InitializationCompleted;
        if (_disposed) return;
        await chart.ApplyOptions(new LightweightCharts.Blazor.Customization.Chart.ChartOptions
        {
            AutoSize = true,
            Layout = new LayoutOptions
            {
                Background = new SolidColor { Color = Clr("#1E1E2D") },
                TextColor = Clr("#A0AEC0"),
                FontFamily = "Inter",
                FontSize = 10
            },
            Grid = new GridOptions
            {
                VerticalLines = new GridLineOptions { Color = Clr(255, 255, 255, 4) },
                HorizontalLines = new GridLineOptions { Color = Clr(255, 255, 255, 4) }
            },
            RightPriceScale = new PriceScaleOptions
            {
                BorderVisible = false,
            },
            TimeScale = new TimeScaleOptions
            {
                BorderVisible = false,
                FixLeftEdge = true,
                FixRightEdge = true,
                RightOffset = 0,
                LockVisibleTimeRangeOnResize = true
            },
            Crosshair = new CrosshairOptions { Mode = CrosshairMode.Magnet }
        });
    }

    private async Task UpdateMomData()
    {
        if (_momRef is null || _disposed) return;
        _momLastHover = null;
        _momLookup.Clear();

        var top5 = TopMomentum.Take(5).ToList();
        var cutoff = GetMomCutoff();

        // Phase 1: prepare all data arrays — rebased to 0% at cutoff start
        var prepared = new LineData<long>[5][];
        long minTime = long.MaxValue, maxTime = long.MinValue;

        for (var i = 0; i < 5; i++)
        {
            if (i >= top5.Count
                || !_momClosesData.TryGetValue(top5[i].Symbol, out var closes)
                || closes.Count == 0)
            {
                prepared[i] = Array.Empty<LineData<long>>();
                continue;
            }

            var sym = top5[i].Symbol;
            var filtered = cutoff.HasValue
                ? closes.Where(c => c.Date >= cutoff.Value).ToList()
                : closes;
            if (filtered.Count == 0 || filtered[0].Close == 0)
            {
                prepared[i] = Array.Empty<LineData<long>>();
                continue;
            }

            var baseClose = filtered[0].Close;
            var data = filtered.Select(c => new LineData<long>
            {
                Time = new DateTimeOffset(c.Date, TimeSpan.Zero).ToUnixTimeSeconds(),
                Value = (c.Close / baseClose - 1) * 100
            }).ToArray();
            prepared[i] = data;

            if (data.Length > 0)
            {
                if (data[0].Time < minTime) minTime = data[0].Time;
                if (data[^1].Time > maxTime) maxTime = data[^1].Time;
            }

            foreach (var d in data)
            {
                if (!_momLookup.ContainsKey(d.Time))
                    _momLookup[d.Time] = (DateTimeOffset.FromUnixTimeSeconds(d.Time).DateTime, new());
                _momLookup[d.Time].Values[sym] = d.Value;
            }
        }

        // Sequential JS interop — parallel SetData calls deadlock the Blazor Server SignalR circuit
        for (var i = 0; i < 5; i++)
        {
            if (_momSeriesRefs[i] is not null)
                await _momSeriesRefs[i]!.SetData(prepared[i]);
        }

        var ts = await _momRef.TimeScale();
        if (minTime < long.MaxValue)
            await ts.SetVisibleRange(new TimeRange { From = minTime, To = maxTime });
        else
            await ts.FitContent();
        await SendMomTooltipData();
    }

    private async Task SendMomTooltipData()
    {
        if (_jsModule is null) return;
        var top5 = TopMomentum.Take(5).ToList();
        var jsLookup = _momLookup.ToDictionary(
            k => k.Key.ToString(),
            k => new { date = k.Value.Date.ToString("dd MMM yyyy"), values = k.Value.Values });
        var symbols = top5.Select((s, i) => new { key = s.Symbol, name = s.Symbol, color = MomSeriesColors[i] }).ToArray();
        await _jsModule.InvokeVoidAsync("setTooltipData", _momContainer, jsLookup, symbols, new { colorBySign = true });
    }

    // ── Radar + Donut ──

    // Returns [Value, Momentum, Sentiment, Quality, Governance] as 0–100 values for the radar chart.
    private double[] ComputeRadarData()
    {
        // breadth = percentage of the index's stocks scoring above the global (all-index) median.
        // This measures how "tilted" an index is toward a factor vs the full universe.
        static double breadth(IEnumerable<double?> indexScores, IEnumerable<double?> allScores)
        {
            var all = allScores.Where(s => s.HasValue).Select(s => s!.Value).OrderBy(x => x).ToList();
            if (all.Count == 0) return 50;
            var median = all[all.Count / 2];
            var idx = indexScores.Where(s => s.HasValue).Select(s => s!.Value).ToList();
            return idx.Count == 0 ? 50 : idx.Count(s => s > median) * 100.0 / idx.Count;
        }

        var d = _daily.Where(x => x.Index == _selectedSignalIndex).ToList();
        var q = _quarterly.Where(x => x.Index == _selectedSignalIndex).ToList();
        return
        [
            breadth(d.Select(x => x.RelativeValueScore), _daily.Select(x => x.RelativeValueScore)),
            breadth(d.Select(x => x.MomentumScore), _daily.Select(x => x.MomentumScore)),
            breadth(d.Select(x => x.SentimentScore), _daily.Select(x => x.SentimentScore)),
            breadth(q.Select(x => x.QualityScore), _quarterly.Select(x => x.QualityScore)),
            breadth(q.Select(x => x.GovernanceScore), _quarterly.Select(x => x.GovernanceScore)),
        ];
    }

    private (string[] Labels, string[] Names, double[] DisplayWeights, double[] RealWeights, string[] Colors,
             string[] SectorLabels, double[] SectorDisplayWeights, double[] SectorRealWeights, string[] SectorColors) ComputeDonutData()
    {
        var stocks = _daily
            .Where(x => x.Index == _selectedSignalIndex && x.IndexWeight.HasValue && x.IndexWeight > 0)
            .OrderByDescending(x => x.MarketCap ?? 0)
            .ToList();

        var labels = stocks.Select(s => s.Symbol).ToArray();
        var names = stocks.Select(s => s.ShortName ?? s.Symbol).ToArray();
        var realWeights = stocks.Select(s => s.IndexWeight!.Value * 100).ToArray();
        var displayWeights = NormalizeForDisplay(realWeights);
        var colors = GenerateStockColors(stocks.Count);

        var sectors = stocks
            .GroupBy(s => s.Sector ?? "Other")
            .OrderByDescending(g => g.Sum(s => s.IndexWeight!.Value))
            .ToList();
        var sectorLabels = sectors.Select(g => g.Key).ToArray();
        var sectorRealWeights = sectors.Select(g => g.Sum(s => s.IndexWeight!.Value) * 100).ToArray();
        var sectorDisplayWeights = NormalizeForDisplay(sectorRealWeights);
        var sectorColors = sectorLabels.Select(s => _sectorColors.GetValueOrDefault(s, "#A0AEC0")).ToArray();

        return (labels, names, displayWeights, realWeights, colors, sectorLabels, sectorDisplayWeights, sectorRealWeights, sectorColors);
    }

    // Cube-root scaling for donut slices: without this, small-cap stocks are invisible slivers.
    // cbrt compresses the range so a 0.1% weight still renders as a visible arc, while large
    // weights stay dominant. Rescales so the total still sums to the original.
    private static double[] NormalizeForDisplay(double[] weights)
    {
        if (weights.Length == 0) return weights;
        var scaled = weights.Select(w => Math.Cbrt(w)).ToArray();
        var scaledSum = scaled.Sum();
        var origSum = weights.Sum();
        if (scaledSum == 0) return weights;
        return scaled.Select(s => s / scaledSum * origSum).ToArray();
    }

    private static string[] GenerateStockColors(int count)
    {
        // Blue shades — wide range for good contrast between tiles
        var colors = new string[count];
        for (int i = 0; i < count; i++)
        {
            var lightness = 18 + (i * 47.0 / Math.Max(count - 1, 1));
            colors[i] = $"hsl(220, 50%, {lightness:F0}%)";
        }
        return colors;
    }

    private static readonly Dictionary<string, string> _sectorColors = new()
    {
        ["Technology"] = "#42A5F5", ["Healthcare"] = "#26A69A", ["Financial Services"] = "#FFA726",
        ["Consumer Cyclical"] = "#AB47BC", ["Industrials"] = "#78909C", ["Communication Services"] = "#EF5350",
        ["Energy"] = "#8D6E63", ["Consumer Defensive"] = "#66BB6A", ["Utilities"] = "#FFCA28",
        ["Real Estate"] = "#5C6BC0", ["Basic Materials"] = "#EC407A",
    };

    // JS init returns false if the canvas element isn't found (not yet in DOM).
    // The caller in OnAfterRenderAsync will retry on the next render cycle.
    private async Task InitRadarChart()
    {
        var data = ComputeRadarData();
        var labels = new[] { "Value", "Momentum", "Sentiment", "Quality", "Governance" };
        var created = await _jsModule!.InvokeAsync<bool>("initRadarChart", "radarChart", labels, data, FormatIndexName(_selectedSignalIndex));
        _radarReady = created;
    }

    private async Task UpdateRadarChart()
    {
        var data = ComputeRadarData();
        await _jsModule!.InvokeVoidAsync("updateRadarChart", data, FormatIndexName(_selectedSignalIndex));
    }

    private async Task InitDonutChart()
    {
        var (labels, names, displayWeights, realWeights, colors, sectorLabels, sectorDisplayWeights, sectorRealWeights, sectorColors) = ComputeDonutData();
        var created = await _jsModule!.InvokeAsync<bool>("initDonutChart", "donutChart",
            labels, names, displayWeights, realWeights, colors,
            sectorLabels, sectorDisplayWeights, sectorRealWeights, sectorColors, _selectedSignalIndex);
        _donutReady = created;
    }

    private async Task UpdateDonutChart()
    {
        var (labels, names, displayWeights, realWeights, colors, sectorLabels, sectorDisplayWeights, sectorRealWeights, sectorColors) = ComputeDonutData();
        await _jsModule!.InvokeVoidAsync("updateDonutChart",
            labels, names, displayWeights, realWeights, colors,
            sectorLabels, sectorDisplayWeights, sectorRealWeights, sectorColors, _selectedSignalIndex);
    }

    // ── Batched line chart updates ──
    // All 3 line charts (synthetic, rolling, volatility) are updated in a SINGLE JS interop
    // call via batchUpdateCharts(). This bypasses the Blazor wrapper's per-call overhead
    // (each SetData/SetVisibleRange/setTooltipData was a separate SignalR round-trip).
    // IJSObjectReferences are extracted via the library's IJsObjectWrapper.JsObjectReference
    // property and passed to our JS module, which resolves them through the library's
    // stored-reference map and calls the LightweightCharts API directly.

    private long _rollMinTime, _rollMaxTime;
    private long _volMinTime, _volMaxTime;

    // Prepares chart data in C# (no interop), returns the arrays for batch push.
    private LineData<long>[] PrepareChartData()
    {
        _lastHoverTime = null;
        _tsLookup.Clear();

        var cutoff = GetPeriodCutoff();
        var allData = _perfByIndex.GetValueOrDefault(_selectedSignalIndex) ?? [];
        var filtered = cutoff.HasValue
            ? allData.Where(p => p.PerfDate >= cutoff.Value).ToList()
            : allData;

        if (filtered.Count == 0) return [];

        var baseVal = filtered[0].CumulativeFactor ?? 1;
        var data = filtered.Select(p => new LineData<long>
        {
            Time = new DateTimeOffset(p.PerfDate, TimeSpan.Zero).ToUnixTimeSeconds(),
            Value = ((p.CumulativeFactor ?? 1) / baseVal - 1) * 100
        }).ToArray();

        foreach (var d in data)
        {
            if (!_tsLookup.ContainsKey(d.Time))
                _tsLookup[d.Time] = (DateTimeOffset.FromUnixTimeSeconds(d.Time).DateTime, new());
            _tsLookup[d.Time].Values[_selectedSignalIndex] = d.Value;
        }
        return data;
    }

    private LineData<long>[] PrepareSimpleSeriesData(
        Dictionary<long, (DateTime Date, Dictionary<string, double> Values)> lookup,
        Func<IndexPerformance, double?> valueSelector,
        out long minTime, out long maxTime)
    {
        lookup.Clear();
        minTime = long.MaxValue; maxTime = long.MinValue;

        var allData = _perfByIndex.GetValueOrDefault(_selectedSignalIndex) ?? [];
        var data = allData
            .Where(p => valueSelector(p).HasValue)
            .Select(p => new LineData<long>
            {
                Time = new DateTimeOffset(p.PerfDate, TimeSpan.Zero).ToUnixTimeSeconds(),
                Value = (valueSelector(p) ?? 0) * 100
            }).ToArray();

        foreach (var d in data)
        {
            if (!lookup.ContainsKey(d.Time))
                lookup[d.Time] = (DateTimeOffset.FromUnixTimeSeconds(d.Time).DateTime, new());
            lookup[d.Time].Values[_selectedSignalIndex] = d.Value;
        }

        if (data.Length > 0) { minTime = data[0].Time; maxTime = data[^1].Time; }
        return data;
    }

    private object BuildTooltipLookup(Dictionary<long, (DateTime Date, Dictionary<string, double> Values)> lookup)
    {
        return lookup.ToDictionary(
            k => k.Key.ToString(),
            k => new { date = k.Value.Date.ToString("dd MMM yyyy"), values = k.Value.Values });
    }

    private (long From, long To) GetVisibleRange(long dataMin, long dataMax)
    {
        var cutoff = GetPeriodCutoff();
        if (cutoff.HasValue)
        {
            var cutoffTs = new DateTimeOffset(cutoff.Value, TimeSpan.Zero).ToUnixTimeSeconds();
            return (Math.Max(cutoffTs, dataMin), dataMax);
        }
        return (dataMin, dataMax);
    }

    // Pushes all 3 line charts in a single JS interop call.
    private async Task BatchUpdateAllLineCharts()
    {
        if (_jsModule is null) return;

        var chartData = PrepareChartData();
        var rollData = PrepareSimpleSeriesData(_rollLookup, p => p.Rolling30dReturn, out _rollMinTime, out _rollMaxTime);
        var volData = PrepareSimpleSeriesData(_volLookup, p => p.Rolling30dVolatility, out _volMinTime, out _volMaxTime);

        var charts = new List<object>();
        var tooltips = new List<object>();
        var ttIndices = new[] { new { key = _selectedSignalIndex, name = FormatIndexName(_selectedSignalIndex), color = IndexColor(_selectedSignalIndex) } };

        if (_chartReady)
        {
            var (from, to) = chartData.Length > 0 ? (chartData[0].Time, chartData[^1].Time) : (0L, 0L);
            charts.Add(new {
                chartRef = _chartJsRef,
                series = _chartSeriesRef!,
                timeScale = _chartTimeScaleRef!,
                data = chartData,
                from = chartData.Length > 0 ? (long?)from : null,
                to = chartData.Length > 0 ? (long?)to : null
            });
            tooltips.Add(new { container = _chartContainer, lookup = BuildTooltipLookup(_tsLookup), indices = ttIndices, options = new { colorBySign = true } });
        }

        if (_rollReady)
        {
            var (from, to) = GetVisibleRange(_rollMinTime, _rollMaxTime);
            charts.Add(new {
                chartRef = _rollJsRef,
                series = _rollSeriesRef!,
                timeScale = _rollTimeScaleRef!,
                data = rollData,
                from = rollData.Length > 0 ? (long?)from : null,
                to = rollData.Length > 0 ? (long?)to : null
            });
            tooltips.Add(new { container = _rollContainer, lookup = BuildTooltipLookup(_rollLookup), indices = ttIndices, options = new { colorBySign = true } });
        }

        if (_volReady)
        {
            var (from, to) = GetVisibleRange(_volMinTime, _volMaxTime);
            charts.Add(new {
                chartRef = _volJsRef,
                series = _volSeriesRef!,
                timeScale = _volTimeScaleRef!,
                data = volData,
                from = volData.Length > 0 ? (long?)from : null,
                to = volData.Length > 0 ? (long?)to : null
            });
            tooltips.Add(new { container = _volContainer, lookup = BuildTooltipLookup(_volLookup), indices = ttIndices, options = new { colorBySign = false } });
        }

        if (charts.Count > 0)
            await _jsModule.InvokeVoidAsync("batchUpdateCharts", charts, tooltips);
    }

    // Legacy single-chart update (used only by OnAfterRenderAsync when charts init at different times)
    private async Task UpdateChartData()
    {
        if (_chartSeriesRef is null || _chartTimeScaleRef is null) return;
        var data = PrepareChartData();
        var (from, to) = data.Length > 0 ? (data[0].Time, data[^1].Time) : (0L, 0L);
        await _jsModule!.InvokeVoidAsync("batchUpdateCharts",
            new[] { new {
                chartRef = _chartJsRef,
                series = _chartSeriesRef,
                timeScale = _chartTimeScaleRef,
                data,
                from = data.Length > 0 ? (long?)from : null,
                to = data.Length > 0 ? (long?)to : null
            }},
            new[] { new {
                container = _chartContainer,
                lookup = BuildTooltipLookup(_tsLookup),
                indices = new[] { new { key = _selectedSignalIndex, name = FormatIndexName(_selectedSignalIndex), color = IndexColor(_selectedSignalIndex) } },
                options = new { colorBySign = true }
            }});
    }

