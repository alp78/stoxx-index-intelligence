        .Where(q => q.Index == _selectedSignalIndex)
        .OrderBy(q => q.QualityRank).Take(10);

    private static readonly (string Key, Func<DateTime, DateTime?> GetStart)[] _periods =
    [
        ("1M", now => now.AddMonths(-1)),
        ("3M", now => now.AddMonths(-3)),
        ("6M", now => now.AddMonths(-6)),
        ("1Y", now => now.AddYears(-1)),
        ("3Y", now => now.AddYears(-3)),
        ("YTD", now => new DateTime(now.Year, 1, 1)),
        ("ALL", _ => null),
    ];

    private static readonly Dictionary<string, string> _indexColors = new()
    {
        ["euro_stoxx_50"] = "#4285F4",
        ["stoxx_usa_50"] = "#FFFFFF",
        ["stoxx_asia_50"] = "#EF5350",
    };

    private static string IndexColor(string key) => _indexColors.GetValueOrDefault(key, "#A0AEC0");

    protected override async Task OnInitializedAsync()
    {
        var snapshotsTask = PerfRepo.GetLatestSnapshotAsync();
        var perfTask = PerfRepo.GetPerformanceAsync();
        var dailyTask = ScoresRepo.GetDailyScoresAsync();
        var quarterlyTask = ScoresRepo.GetQuarterlyScoresAsync();
        var keysTask = StockRepo.GetIndexKeysAsync();

        await Task.WhenAll(snapshotsTask, perfTask, dailyTask, quarterlyTask, keysTask);

        _snapshots = (await snapshotsTask).ToList();
        _daily = (await dailyTask).ToList();
        _quarterly = (await quarterlyTask).ToList();

        var keys = (await keysTask).ToList();
        if (keys.Count != 0)
            _selectedSignalIndex = keys.First();

        var perf = (await perfTask).ToList();
        _perfByIndex = perf
            .GroupBy(p => p.Index)
            .ToDictionary(g => g.Key, g =>
            {
                var ordered = g.OrderBy(p => p.PerfDate).ToList();
                while (ordered.Count > 1 && Math.Abs(ordered[^1].DailyReturn ?? 0) < 0.0001)
                    ordered.RemoveAt(ordered.Count - 1);
                return ordered;
            });

        _indexKeys = _snapshots.Select(s => s.Index).OrderBy(k => k).ToArray();

        foreach (var key in _indexKeys)
        {
            _seriesRefs[key] = null;
            _rollSeriesRefs[key] = null;
            _volSeriesRefs[key] = null;
        }

        await LoadMomentumCloses();
        _loading = false;

        _clockTimer = new System.Threading.Timer(_ =>
            InvokeAsync(StateHasChanged), null, TimeSpan.Zero, TimeSpan.FromSeconds(10));
    }

    private DateTime? GetMomCutoff()
    {
        var p = _momPeriods.FirstOrDefault(p => p.Key == _selectedMomPeriod);
        return p.GetStart?.Invoke(DateTime.UtcNow);
    }

    private async Task LoadMomentumCloses()
    {
        var indexDaily = _daily.Where(d => d.Index == _selectedSignalIndex).ToList();
        var top5 = indexDaily
            .OrderBy(d => d.MomentumRank).Take(5)
            .Select(d => d.Symbol).ToArray();
        if (top5.Length == 0) { _momClosesData.Clear(); return; }

        // Pre-load 3Y + buffer so period switches are instant (just re-filter)
        var latestDate = indexDaily.Max(d => d.ScoreDate);
        var from = latestDate.AddYears(-3).AddMonths(-1);
        var closes = (await StockRepo.GetBatchClosesAsync(_selectedSignalIndex, top5, from)).ToList();
        _momClosesData = closes.GroupBy(c => c.Symbol)
            .ToDictionary(g => g.Key, g => g.OrderBy(c => c.Date).ToList());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import",
                "./Components/Pages/Home.razor.js");
        }

        var tasks = new List<Task>();

        if (!_chartReady && _chartRef is not null)
            tasks.Add(InitSyntheticChart());
        if (!_rollReady && _rollRef is not null)
            tasks.Add(InitRollingChart());
        if (!_volReady && _volRef is not null)
            tasks.Add(InitVolatilityChart());
        if (!_momReady && _momRef is not null)
            tasks.Add(InitMomentumChart());

        if (tasks.Count > 0)
        {
            await Task.WhenAll(tasks);
            StateHasChanged();
        }
    }

    private async Task InitSyntheticChart()
    {
        await InitChartOptions(_chartRef!);
        _chartRef!.CrosshairMoved += OnMainCrosshair;
        foreach (var key in _indexKeys)
        {
            _seriesRefs[key] = await _chartRef!.AddSeries<LineStyleOptions>(
                SeriesType.Line,
                new LineStyleOptions
                {
                    Color = Clr(IndexColor(key)),
                    LineWidth = 1,
                    CrosshairMarkerVisible = false,
                    LastValueVisible = false,
                    PriceLineVisible = false
                });
        }
        await UpdateChartData();
        _chartReady = true;
    }

    private async Task InitRollingChart()
    {
        await InitChartOptions(_rollRef!);
        _rollRef!.CrosshairMoved += OnRollCrosshair;
        foreach (var key in _indexKeys)
        {
            _rollSeriesRefs[key] = await _rollRef!.AddSeries<LineStyleOptions>(
                SeriesType.Line,
                new LineStyleOptions
                {
                    Color = Clr(IndexColor(key)),
                    LineWidth = 1,
                    CrosshairMarkerVisible = false,
                    LastValueVisible = false,
                    PriceLineVisible = false
                });
        }
        await UpdateRollingData();
        _rollReady = true;
    }

    private async Task InitVolatilityChart()
    {
        await InitChartOptions(_volRef!);
        _volRef!.CrosshairMoved += OnVolCrosshair;
        foreach (var key in _indexKeys)
        {
            _volSeriesRefs[key] = await _volRef!.AddSeries<LineStyleOptions>(
