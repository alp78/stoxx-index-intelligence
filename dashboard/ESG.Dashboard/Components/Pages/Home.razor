    private async Task InitSparklineOptions(ChartComponent chart)
    {
        await chart.InitializationCompleted;
        await chart.ApplyOptions(new LightweightCharts.Blazor.Customization.Chart.ChartOptions
        {
            AutoSize = true,
            Layout = new LayoutOptions
            {
                Background = new SolidColor { Color = Clr("#1E1E2D") },
                TextColor = Clr("#A0AEC0"),
                FontFamily = "Inter",
                FontSize = 10
            },
            Grid = new GridOptions
            {
                VerticalLines = new GridLineOptions { Color = Clr(255, 255, 255, 4) },
                HorizontalLines = new GridLineOptions { Color = Clr(255, 255, 255, 4) }
            },
            RightPriceScale = new PriceScaleOptions
            {
                BorderVisible = false,
            },
            TimeScale = new TimeScaleOptions
            {
                BorderVisible = false,
                FixLeftEdge = true,
                FixRightEdge = true,
                RightOffset = 0,
                LockVisibleTimeRangeOnResize = true
            },
            Crosshair = new CrosshairOptions { Mode = CrosshairMode.Magnet }
        });
    }

    private async Task UpdateMomData()
    {
        if (_momRef is null) return;
        _momLastHover = null;
        _momLookup.Clear();

        var top5 = TopMomentum.Take(5).ToList();
        var cutoff = GetMomCutoff();

        // Phase 1: prepare all data arrays — filtered by calendar cutoff
        var prepared = new LineData<long>[5][];
        long minTime = long.MaxValue, maxTime = long.MinValue;

        for (var i = 0; i < 5; i++)
        {
            if (i >= top5.Count
                || !_momClosesData.TryGetValue(top5[i].Symbol, out var closes)
                || closes.Count == 0)
            {
                prepared[i] = Array.Empty<LineData<long>>();
                continue;
            }

            var sym = top5[i].Symbol;
            var filtered = cutoff.HasValue
                ? closes.Where(c => c.Date >= cutoff.Value).ToList()
                : closes;
            if (filtered.Count == 0 || filtered[0].Close == 0)
            {
                prepared[i] = Array.Empty<LineData<long>>();
                continue;
            }

            var baseClose = filtered[0].Close;
            var data = filtered.Select(c => new LineData<long>
            {
                Time = new DateTimeOffset(c.Date, TimeSpan.Zero).ToUnixTimeSeconds(),
                Value = (c.Close / baseClose - 1) * 100
            }).ToArray();
            prepared[i] = data;

            if (data.Length > 0)
            {
                if (data[0].Time < minTime) minTime = data[0].Time;
                if (data[^1].Time > maxTime) maxTime = data[^1].Time;
            }

            foreach (var d in data)
            {
                if (!_momLookup.ContainsKey(d.Time))
                    _momLookup[d.Time] = (DateTimeOffset.FromUnixTimeSeconds(d.Time).DateTime, new());
                _momLookup[d.Time].Values[sym] = d.Value;
            }
        }

        // Phase 2: push all series data + set visible range in one batch (no intermediate render)
        var ts = await _momRef.TimeScale();
        var setTasks = new List<Task>(6);
        for (var i = 0; i < 5; i++)
        {
            if (_momSeriesRefs[i] is not null)
                setTasks.Add(_momSeriesRefs[i]!.SetData(prepared[i]));
        }
        if (minTime < long.MaxValue)
            setTasks.Add(ts.SetVisibleRange(new TimeRange { From = minTime, To = maxTime }));
        else
            setTasks.Add(ts.FitContent());
        await Task.WhenAll(setTasks);
        await SendMomTooltipData();
    }

    private async Task SendMomTooltipData()
    {
        if (_jsModule is null) return;
        var top5 = TopMomentum.Take(5).ToList();
        var jsLookup = _momLookup.ToDictionary(
            k => k.Key.ToString(),
            k => new { date = k.Value.Date.ToString("dd MMM yyyy"), values = k.Value.Values });
        var symbols = top5.Select((s, i) => new { key = s.Symbol, name = s.Symbol, color = MomSeriesColors[i] }).ToArray();
        await _jsModule.InvokeVoidAsync("setTooltipData", _momContainer, jsLookup, symbols, new { colorBySign = true });
    }

    private async Task InitChartOptions(ChartComponent chart)
    {
        await chart.InitializationCompleted;
        await chart.ApplyOptions(new LightweightCharts.Blazor.Customization.Chart.ChartOptions
        {
            AutoSize = true,
            Layout = new LayoutOptions
            {
                Background = new SolidColor { Color = Clr("#1E1E2D") },
                TextColor = Clr("#A0AEC0"),
                FontFamily = "Inter",
                FontSize = 11
            },
            Grid = new GridOptions
            {
                VerticalLines = new GridLineOptions { Color = Clr(255, 255, 255, 6) },
                HorizontalLines = new GridLineOptions { Color = Clr(255, 255, 255, 6) }
            },
            RightPriceScale = new PriceScaleOptions { BorderVisible = false },
            TimeScale = new TimeScaleOptions
            {
                BorderVisible = false,
                FixLeftEdge = true,
                FixRightEdge = true,
                RightOffset = 0,
                LockVisibleTimeRangeOnResize = true
            },
            Crosshair = new CrosshairOptions { Mode = CrosshairMode.Magnet }
        });
    }

    // ── Main chart series (rebased cumulative return) ──

    private async Task UpdateChartData()
    {
        if (_chartRef is null) return;
        _lastHoverTime = null;
        _tsLookup.Clear();

        var cutoff = GetPeriodCutoff();

        // Phase 1: prepare all data arrays (pure C#, no JS interop)
        var prepared = new Dictionary<string, LineData<long>[]>();
        foreach (var key in _indexKeys)
        {
            if (!_seriesRefs.ContainsKey(key) || _seriesRefs[key] is null) continue;

            var allData = _perfByIndex.GetValueOrDefault(key) ?? [];
            var filtered = cutoff.HasValue
                ? allData.Where(p => p.PerfDate >= cutoff.Value).ToList()
                : allData;
            if (filtered.Count == 0) { prepared[key] = Array.Empty<LineData<long>>(); continue; }

            var baseVal = filtered[0].CumulativeFactor ?? 1;

            var data = filtered.Select(p => new LineData<long>
            {
                Time = new DateTimeOffset(p.PerfDate, TimeSpan.Zero).ToUnixTimeSeconds(),
                Value = ((p.CumulativeFactor ?? 1) / baseVal - 1) * 100
            }).ToArray();
            prepared[key] = data;

            foreach (var d in data)
            {
                if (!_tsLookup.ContainsKey(d.Time))
                    _tsLookup[d.Time] = (DateTimeOffset.FromUnixTimeSeconds(d.Time).DateTime, new());
                _tsLookup[d.Time].Values[key] = d.Value;
            }
        }

        // Phase 2: push all series data + set visible range in one batch
        long minTime = long.MaxValue, maxTime = long.MinValue;
        foreach (var arr in prepared.Values)
        {
            if (arr.Length > 0)
            {
                if (arr[0].Time < minTime) minTime = arr[0].Time;
                if (arr[^1].Time > maxTime) maxTime = arr[^1].Time;
            }
        }

        var timeScale = await _chartRef.TimeScale();
        var setTasks = prepared
            .Where(kv => _seriesRefs[kv.Key] is not null)
            .Select(kv => _seriesRefs[kv.Key]!.SetData(kv.Value))
            .ToList();
        if (minTime < long.MaxValue)
            setTasks.Add(timeScale.SetVisibleRange(new TimeRange { From = minTime, To = maxTime }));
        else
            setTasks.Add(timeScale.FitContent());
        await Task.WhenAll(setTasks);

        await SendTooltipData(_chartContainer, _tsLookup, true);
    }

    // ── Shared helper for rolling return / volatility charts ──

    private async Task UpdateSimpleSeries(
        ChartComponent chart,
        Dictionary<string, ISeriesApi<long>?> seriesRefs,
        Dictionary<long, (DateTime Date, Dictionary<string, double> Values)> lookup,
        ElementReference container,
        Func<IndexPerformance, double?> valueSelector,
        bool colorBySign)
    {
        var cutoff = GetPeriodCutoff();
        lookup.Clear();

        // Phase 1: prepare all data arrays (pure C#, no JS interop)
        var prepared = new Dictionary<string, LineData<long>[]>();
        foreach (var key in _indexKeys)
        {
            var series = seriesRefs.GetValueOrDefault(key);
            if (series is null) continue;

            var allData = _perfByIndex.GetValueOrDefault(key) ?? [];
            var filtered = cutoff.HasValue
                ? allData.Where(p => p.PerfDate >= cutoff.Value).ToList()
                : allData.ToList();

            var points = filtered
                .Where(p => valueSelector(p).HasValue)
                .Select(p => new LineData<long>
                {
                    Time = new DateTimeOffset(p.PerfDate, TimeSpan.Zero).ToUnixTimeSeconds(),
                    Value = (valueSelector(p) ?? 0) * 100
                }).ToArray();
            prepared[key] = points;

            foreach (var d in points)
            {
                if (!lookup.ContainsKey(d.Time))
                    lookup[d.Time] = (DateTimeOffset.FromUnixTimeSeconds(d.Time).DateTime, new());
                lookup[d.Time].Values[key] = d.Value;
            }
        }

        // Phase 2: push all series data + set visible range in one batch
        long minTime = long.MaxValue, maxTime = long.MinValue;
        foreach (var arr in prepared.Values)
        {
            if (arr.Length > 0)
            {
                if (arr[0].Time < minTime) minTime = arr[0].Time;
                if (arr[^1].Time > maxTime) maxTime = arr[^1].Time;
            }
        }

        var ts = await chart.TimeScale();
        var setTasks = prepared
            .Where(kv => seriesRefs[kv.Key] is not null)
            .Select(kv => seriesRefs[kv.Key]!.SetData(kv.Value))
            .ToList();
        if (minTime < long.MaxValue)
            setTasks.Add(ts.SetVisibleRange(new TimeRange { From = minTime, To = maxTime }));
        else
            setTasks.Add(ts.FitContent());
        await Task.WhenAll(setTasks);

        await SendTooltipData(container, lookup, colorBySign);
    }

    private Task UpdateRollingData() =>
        UpdateSimpleSeries(_rollRef!, _rollSeriesRefs, _rollLookup, _rollContainer,
            p => p.Rolling30dReturn, true);

    private Task UpdateVolatilityData() =>
        UpdateSimpleSeries(_volRef!, _volSeriesRefs, _volLookup, _volContainer,
            p => p.Rolling30dVolatility, false);

    // ── Period & tooltip helpers ──

    private DateTime? GetPeriodCutoff()
    {
        var p = _periods.FirstOrDefault(p => p.Key == _selectedPeriod);
        return p.GetStart?.Invoke(DateTime.UtcNow);
    }

    private async Task SendTooltipData(ElementReference container,
        Dictionary<long, (DateTime Date, Dictionary<string, double> Values)> lookup, bool colorBySign)
    {
        if (_jsModule is null) return;
        var jsLookup = lookup.ToDictionary(
            k => k.Key.ToString(),
            k => new { date = k.Value.Date.ToString("dd MMM yyyy"), values = k.Value.Values });
        var indices = _indexKeys.Select(k => new { key = k, name = FormatIndexName(k), color = IndexColor(k) }).ToArray();
        await _jsModule.InvokeVoidAsync("setTooltipData", container, jsLookup, indices, new { colorBySign });
    }

    private async Task OnSignalIndexChanged(string newIndex)
    {
        _selectedSignalIndex = newIndex;
        await LoadMomentumCloses();
        if (_momReady)
            await UpdateMomData();
    }

    private async Task SetMomPeriod(string period)
    {
        _selectedMomPeriod = period;
        if (_momReady)
        {
            _momTransitioning = true;
            StateHasChanged();
            await Task.Delay(20);
            await UpdateMomData();
            _momTransitioning = false;
        }
    }

    private async Task SetPeriod(string period)
    {
        _selectedPeriod = period;
        var tasks = new List<Task> { UpdateChartData() };
        if (_rollReady) tasks.Add(UpdateRollingData());
        if (_volReady) tasks.Add(UpdateVolatilityData());
        await Task.WhenAll(tasks);
    }

    // ── Crosshair handlers ──

    private void OnMainCrosshair(object? sender, LightweightCharts.Blazor.Models.Events.MouseEventParams<long> e)
        => HandleCrosshair(e, ref _lastHoverTime, _chartContainer);

    private void OnRollCrosshair(object? sender, LightweightCharts.Blazor.Models.Events.MouseEventParams<long> e)
        => HandleCrosshair(e, ref _rollLastHover, _rollContainer);

    private void OnVolCrosshair(object? sender, LightweightCharts.Blazor.Models.Events.MouseEventParams<long> e)
        => HandleCrosshair(e, ref _volLastHover, _volContainer);

    private void OnMomCrosshair(object? sender, LightweightCharts.Blazor.Models.Events.MouseEventParams<long> e)
        => HandleCrosshair(e, ref _momLastHover, _momContainer);

    private void HandleCrosshair(LightweightCharts.Blazor.Models.Events.MouseEventParams<long> e,
        ref long? lastHover, ElementReference container)
    {
        if (_disposed) return;
        if (e.Time is null)
        {
            if (lastHover is not null)
            {
                lastHover = null;
                _ = InvokeAsync(() => _jsModule?.InvokeVoidAsync("hideTooltip", container));
            }
            return;
        }
        if (e.Time == lastHover) return;
        lastHover = e.Time;
        if (e.Point is not null)
            _ = InvokeAsync(() => _jsModule?.InvokeVoidAsync("showTooltip", container, e.Point.X, e.Point.Y, e.Time.Value));
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_clockTimer is not null) await _clockTimer.DisposeAsync();

        // Unsubscribe crosshair events before chart components dispose themselves
        if (_chartRef is not null) _chartRef.CrosshairMoved -= OnMainCrosshair;
        if (_rollRef is not null) _rollRef.CrosshairMoved -= OnRollCrosshair;
        if (_volRef is not null) _volRef.CrosshairMoved -= OnVolCrosshair;
        if (_momRef is not null) _momRef.CrosshairMoved -= OnMomCrosshair;

        if (_jsModule is not null)
        {
            try { await _jsModule.DisposeAsync(); }
            catch (Microsoft.JSInterop.JSDisconnectedException) { }
        }
    }

