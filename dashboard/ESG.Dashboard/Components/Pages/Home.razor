                        <MudSimpleTable Dense="true" Hover="true" Class="compact-table">
                            <thead><tr><th>#</th><th></th><th>Symbol</th><th>Score</th><th style="width: 60px;"></th></tr></thead>
                            <tbody>
                                @foreach (var s in TopValue)
                                {
                                    <tr>
                                        <td>@s.RelativeValueRank</td>
