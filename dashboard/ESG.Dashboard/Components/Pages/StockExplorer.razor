@* ───────────────────────────────────────────────────────────────────
   Stock Explorer — per-index stock list with detail panel.
   Left nav: filterable, market-cap ranked stock table.
   Right panel: OHLCV chart, score gauges, and quarterly health flags.
   Supports deep-linking via /stocks/{IndexKey}/{Symbol}.
   ─────────────────────────────────────────────────────────────────── *@
@page "/stocks"
@page "/stocks/{IndexKey}/{Symbol}"
@rendermode InteractiveServer
@inject StockRepository StockRepo
@inject ScoresRepository ScoresRepo
@inject IJSRuntime JS
@inject IndexSelectionState IdxState
@inject NavigationManager Nav
@inject CountryFlags Flags
@inject IndexRegistry IdxReg
@implements IAsyncDisposable

<PageTitle>Stocks - STOXX Index Intelligence</PageTitle>

<style>
    @@media (min-width: 960px) {
        .stock-nav-panel { order: -1; }
    }
</style>

@* ── Layout: detail panel (8 cols) + nav panel (4 cols).
   On mobile, detail renders first (DOM order); on desktop, CSS order: -1
   pushes the nav panel to the left so the wider detail sits on the right. ─ *@
@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid Spacing="3">
        <!-- Detail panel (appears first in DOM = first on mobile) -->
        <MudItem xs="12" md="8" Style="min-width: 0; overflow: hidden;">
            @if (_selectedStock is null)
            {
                <MudPaper Class="pa-8 d-flex align-center justify-center" Elevation="2" Style="min-height: 500px;">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Style="font-size: 3rem; opacity: 0.2;" />
                        <MudText Typo="Typo.h6" Style="opacity: 0.3;">Select a stock from the list</MudText>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <!-- Stock identity + latest OHLCV summary bar -->
                <MudPaper Class="pa-3 mb-3" Elevation="2" Style="min-width: 0; overflow: hidden;">
                    <div class="d-flex align-center flex-wrap" style="gap: 12px;">
                        <!-- Stock identity -->
                        <MudTooltip Arrow="true" Placement="Placement.Bottom" Color="Color.Dark">
                            <TooltipContent>
                                <div style="max-width: 360px; font-size: 0.8rem; line-height: 1.5; padding: 4px 0; text-align: left;">
                                    <div style="margin-bottom: 6px;">
                                        <strong>@_selectedStock.ShortName</strong>
                                    </div>
                                    @if (_selectedStock.Country is not null || _selectedStock.City is not null)
                                    {
                                        <div style="margin-bottom: 6px; opacity: 0.85;">
                                            @if (_selectedStock.Country is not null)
                                            {
                                                <span class="fi fi-@Flags.GetCode(_selectedStock.Country)" style="margin-right: 4px;"></span>
                                            }
                                            @(_selectedStock.City is not null ? $"{_selectedStock.City}, " : "")@(_selectedStock.Country ?? "")
                                        </div>
                                    }
                                    @if (_selectedStock.LongBusinessSummary is not null)
                                    {
                                        <div style="opacity: 0.7; white-space: normal;">@_selectedStock.LongBusinessSummary</div>
                                    }
                                </div>
                            </TooltipContent>
                            <ChildContent>
                                <div style="flex-shrink: 0; cursor: help;">
                                    <div class="d-flex align-center" style="gap: 10px;">
                                        <img src="logos/@(_selectedStock.Index)/@(_selectedStock.Symbol).png"
                                             alt="@_selectedStock.Symbol"
                                             style="width: 36px; height: 36px; border-radius: 50%; object-fit: cover; background: rgba(255,255,255,0.1);"
                                             onerror="this.style.display='none'" />
                                        <div>
                                            <MudText Typo="Typo.h5" Style="font-weight: 600;">@_selectedStock.Symbol</MudText>
                                            <MudText Typo="Typo.body2" Style="opacity: 0.6;">@_selectedStock.ShortName</MudText>
                                        </div>
                                    </div>
                                    @if (_selectedStock.Sector is not null || _selectedStock.Industry is not null)
                                    {
                                        <MudText Typo="Typo.caption" Style="opacity: 0.35;">@(_selectedStock.Sector ?? "")@(_selectedStock.Industry is not null ? $": {_selectedStock.Industry}" : "")</MudText>
                                    }
                                </div>
                            </ChildContent>
                        </MudTooltip>

                        <!-- Price numbers fill remaining space -->
                        @if (_latestCandle is not null)
                        {
                            <div style="flex: 1; min-width: 0; display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; text-align: right; padding-right: 72px;">
                                <div>
                                    <MudText Typo="Typo.caption" Style="opacity: 0.4;">PRICE</MudText>
                                    <div class="d-flex align-center justify-end" style="gap: 6px;">
                                        <MudText Typo="Typo.h6" Style="font-weight: 700;">@FmtPrice(_latestCandle.RawClose)</MudText>
                                        @if (_priceChangePct is not null)
                                        {
                                            var up = _priceChangePct >= 0;
                                            <span style="font-size: 0.8em; color: @(up ? "#26A69A" : "#EF5350");">
                                                @(up ? "\u25B2" : "\u25BC") @($"{_priceChangePct:+0.00;-0.00}%")
                                            </span>
                                        }
                                    </div>
                                </div>
                                <div>
                                    <MudText Typo="Typo.caption" Style="opacity: 0.4;">DAY HIGH</MudText>
                                    <MudText>@FmtPrice(_latestCandle.High)</MudText>
                                </div>
                                <div>
                                    <MudText Typo="Typo.caption" Style="opacity: 0.4;">DAY LOW</MudText>
                                    <MudText>@FmtPrice(_latestCandle.Low)</MudText>
                                </div>
                                <div>
                                    <MudText Typo="Typo.caption" Style="opacity: 0.4;">VOLUME</MudText>
                                    <MudText>@FmtVol(_latestCandle.Volume)</MudText>
                                </div>
                            </div>
                        }
                    </div>
                </MudPaper>

                <!-- OHLCV price chart (candlestick + area fill + MA lines + volume histogram) -->
                <MudPaper Class="pa-4 mb-3" Elevation="2" Style="overflow: hidden; min-width: 0;">
                    <!-- Chart legend + period range selector (1M / 3M / 6M / 1Y / 3Y / All) -->
                    <div class="d-flex align-center flex-wrap mb-2" style="gap: 6px; padding-right: 72px;">
                        <span style="font-size: 11px; opacity: 0.5; margin-right: 4px;">
                            <span style="color: #26A69A;">&FilledSmallSquare;</span><span style="color: #EF5350;">&FilledSmallSquare;</span> OHLC
                        </span>
                        <span style="font-size: 11px; color: #42A5F5;">--- MA 30</span>
                        <span style="font-size: 11px; color: #AB47BC;">--- MA 90</span>
                        <span style="font-size: 11px; opacity: 0.4;">&block; VOL</span>
                        <span style="flex: 1;"></span>
                        @foreach (var (label, months) in _ranges)
                        {
                            <MudButton Variant="@(months == _selectedMonths ? Variant.Filled : Variant.Outlined)"
                                       Size="Size.Small" Color="Color.Default"
                                       Style="font-size: 0.7rem; min-width: 32px; padding: 2px 6px; height: 24px;"
                                       OnClick="@(() => SetPriceRange(months))">@label</MudButton>
                        }
                    </div>

                    @* Chart container: hidden (opacity 0) until series are initialized to
                       prevent the empty chart flash. The hover tooltip is absolutely positioned
                       inside this div — its x/y coordinates come from MeasureChartContainerAsync. *@
                    <div @ref="_chartContainer" style="position: relative; width: 100%; height: clamp(280px, 45vw, 520px); overflow: hidden; background: #1E1E2D; opacity: @(_chartReady ? "1" : "0"); transition: opacity 0.15s ease-in;">
                        <ChartComponent @ref="_chart" CssStyle="width: 100%; height: 100%;" />
                        @if (_hoverCandle is not null)
                        {
                            var ttW = 150; var ttH = 190;
                            var tx = _hoverX + 16;
                            var ty = _hoverY - 20;
                            if (_hoverX > _chartWidth - ttW - 30) tx = _hoverX - ttW - 12;
                            if (ty + ttH > _chartHeight) ty = _chartHeight - ttH - 4;
                            if (ty < 0) ty = 4;
                            <div style="position: absolute; left: @(tx)px; top: @(ty)px; z-index: 10;
                                        background: rgba(21,21,33,0.92); padding: 5px 8px;
                                        border-radius: 3px; font-size: 10px; pointer-events: none;
                                        font-family: 'Inter', monospace; line-height: 1.6;
                                        white-space: nowrap;">
                                <div style="opacity: 0.5; margin-bottom: 1px;">@_hoverCandle.Date.ToString("dd/MM/yyyy")</div>
                                <div style="color: #888;"><span style="opacity: 0.5;">O</span> <span style="float: right; margin-left: 10px;">@FmtPrice(_hoverCandle.Open)</span></div>
                                <div style="color: #888;"><span style="opacity: 0.5;">H</span> <span style="float: right; margin-left: 10px;">@FmtPrice(_hoverCandle.High)</span></div>
                                <div style="color: #888;"><span style="opacity: 0.5;">L</span> <span style="float: right; margin-left: 10px;">@FmtPrice(_hoverCandle.Low)</span></div>
                                <div style="color: #fff;"><span style="font-weight: 600;">C</span> <span style="float: right; margin-left: 10px; font-weight: 600;">@FmtPrice(_hoverCandle.RawClose)</span></div>
                                <div style="color: #888;"><span style="opacity: 0.5;">Adj</span> <span style="float: right; margin-left: 10px;">@FmtPrice(_hoverCandle.Close)</span></div>
                                @if (_hoverPrevCandle is not null)
                                {
                                    var diff = (_hoverCandle.RawClose ?? 0) - (_hoverPrevCandle.RawClose ?? 0);
                                    var pct = (_hoverPrevCandle.RawClose ?? 0) != 0 ? diff / (_hoverPrevCandle.RawClose ?? 1) * 100 : 0;
                                    var clr = diff >= 0 ? "#26A69A" : "#EF5350";
                                    <div><span style="opacity: 0.5;">VS</span> <span style="float: right; margin-left: 10px; color: @clr;">@($"{pct:+0.00;-0.00}%")</span></div>
                                }
                                @if (_hoverMa30.HasValue)
                                {
                                    <div style="color: #42A5F5;"><span style="opacity: 0.7;">MA30</span> <span style="float: right; margin-left: 10px;">@FmtPrice(_hoverMa30)</span></div>
                                }
                                @if (_hoverMa90.HasValue)
                                {
                                    <div style="color: #AB47BC;"><span style="opacity: 0.7;">MA90</span> <span style="float: right; margin-left: 10px;">@FmtPrice(_hoverMa90)</span></div>
                                }
                                <div style="opacity: 0.4;"><span>VOL</span> <span style="float: right; margin-left: 10px;">@FmtVol(_hoverCandle.Volume)</span></div>
                            </div>
                        }
                    </div>
                </MudPaper>

                <!-- Chart.js: Stock Radar + Governance Risk — rendered above daily/quarterly analytics -->
                <MudGrid Spacing="3" Class="mb-3">
                    @if (_detailDaily is not null)
                    {
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-4" Elevation="2" Style="min-height: 240px;">
                                <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                                    <ChildContent>
                                        <span style="cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.2); width: fit-content;">
                                            <MudText Typo="Typo.subtitle1" Style="margin: 0; font-weight: 600;">Factor Profile</MudText>
                                        </span>
                                    </ChildContent>
                                    <TooltipContent>
                                        <div style="@_tipStyle">
                                            <div style="@_tipHead">Stock Factor Profile</div>
                                            <div style="@_tipDesc">Percentile rank within the index on five dimensions (100 = top of index):</div>
                                            <ul style="@_tipList">
                                                <li><b>Value</b> &mdash; relative cheapness vs peers</li>
                                                <li><b>Momentum</b> &mdash; trend strength</li>
                                                <li><b>Sentiment</b> &mdash; analyst conviction</li>
                                                <li><b>Quality</b> &mdash; profitability + balance sheet</li>
                                                <li><b>Governance</b> &mdash; ISS risk (inverted: higher = better)</li>
                                            </ul>
                                        </div>
                                    </TooltipContent>
                                </MudTooltip>
                                <div style="position: relative; height: 200px;">
                                    <canvas id="stockRadarChart"></canvas>
                                </div>
                            </MudPaper>
                        </MudItem>
                    }
                    @if (_detailQuarterly is not null)
                    {
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-4" Elevation="2" Style="min-height: 240px;">
                                <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                                    <ChildContent>
                                        <span style="cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.2); width: fit-content;">
                                            <MudText Typo="Typo.subtitle1" Style="margin: 0; font-weight: 600;">Governance Risk</MudText>
                                        </span>
                                    </ChildContent>
                                    <TooltipContent>
                                        <div style="@_tipStyle">
                                            <div style="@_tipHead">ISS Governance Risk</div>
                                            <div style="@_tipDesc">Risk scores on a 1&ndash;10 scale:</div>
                                            <ul style="@_tipColorList">
                                                <li><span style="color: #26A69A;">1&ndash;3</span> Low risk</li>
                                                <li><span style="color: #FFA726;">4&ndash;6</span> Moderate risk</li>
                                                <li><span style="color: #EF5350;">7&ndash;10</span> High risk</li>
                                            </ul>
                                        </div>
                                    </TooltipContent>
                                </MudTooltip>
                                <div style="position: relative; height: 200px;">
                                    <canvas id="govChart"></canvas>
                                </div>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>

                <!-- Daily + Quarterly Analytics: score tables, z-scores, health flags, governance -->
                <MudGrid Spacing="3">
                    @if (_detailDaily is not null)
                    {
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-4" Elevation="2">
                                <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                                    <ChildContent>
                                        <span style="cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.2); width: fit-content;">
                                            <MudText Typo="Typo.h6" Style="margin: 0;">Daily Analytics</MudText>
                                        </span>
                                    </ChildContent>
                                    <TooltipContent>
                                        <div style="@_tipStyle">
                                            <div style="@_tipHead">Daily Scores</div>
                                            <div style="@_tipDesc">Computed daily from market data. Rank = position within the index (1 = best).</div>
                                            <ul style="@_tipList">
                                                <li><b>Composite</b> &mdash; weighted average of Value + Momentum + Sentiment</li>
                                                <li><b>Relative Value</b> &mdash; valuation discount vs peers</li>
                                                <li><b>Momentum</b> &mdash; trend strength</li>
                                                <li><b>Sentiment</b> &mdash; analyst conviction</li>
                                            </ul>
                                            <div style="@_tipNote">Z-scores measure standard deviations from the index cross-sectional median. Positive = above average.</div>
                                        </div>
                                    </TooltipContent>
                                </MudTooltip>
                                <MudText Typo="Typo.caption" Style="opacity: 0.5;">@_detailDaily.ScoreDate.ToString("yyyy-MM-dd")</MudText>
                                <MudSimpleTable Dense="true" Class="mt-2">
                                    <tbody>
                                        <ScoreRow Label="Composite" Score="@_detailDaily.CompositeScore" Rank="@_detailDaily.CompositeRank" />
                                        <ScoreRow Label="Relative Value" Score="@_detailDaily.RelativeValueScore" Rank="@_detailDaily.RelativeValueRank" />
                                        <ScoreRow Label="Momentum" Score="@_detailDaily.MomentumScore" Rank="@_detailDaily.MomentumRank" />
                                        <ScoreRow Label="Sentiment" Score="@_detailDaily.SentimentScore" Rank="@_detailDaily.SentimentRank" />
                                    </tbody>
                                </MudSimpleTable>

                                <MudDivider Class="my-3" />
                                <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                                    <ChildContent>
                                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.15);">Value Metrics</MudText>
                                    </ChildContent>
                                    <TooltipContent>
                                        <div style="@_tipStyle">
                                            <div style="@_tipHead">Value Z-Scores</div>
                                            <div style="@_tipDesc">Cross-sectional z-scores vs index peers (inverted — lower multiples = higher score):</div>
                                            <ul style="@_tipColorList">
                                                <li><span style="color: #26A69A;">&lt; 0</span> &mdash; cheaper than median</li>
                                                <li><span style="color: #A0A0B0;">&asymp; 0</span> &mdash; near median valuation</li>
                                                <li><span style="color: #EF5350;">&gt; 0</span> &mdash; more expensive than median</li>
                                            </ul>
                                            <div style="@_tipNote">Combined into the Relative Value composite score.</div>
                                        </div>
                                    </TooltipContent>
                                </MudTooltip>
                                <MudSimpleTable Dense="true">
                                    <tbody>
                                        <tr><td>PE Z-Score</td><td>@F(_detailDaily.PeZscore)</td></tr>
                                        <tr><td>PB Z-Score</td><td>@F(_detailDaily.PbZscore)</td></tr>
                                        <tr><td>EV/EBITDA Z-Score</td><td>@F(_detailDaily.EvEbitdaZscore)</td></tr>
                                        <tr><td>Yield Z-Score</td><td>@F(_detailDaily.YieldZscore)</td></tr>
                                    </tbody>
                                </MudSimpleTable>

                                <MudDivider Class="my-3" />
                                <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                                    <ChildContent>
                                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.15);">Momentum</MudText>
                                    </ChildContent>
                                    <TooltipContent>
                                        <div style="@_tipStyle">
                                            <div style="@_tipHead">Momentum Components</div>
                                            <ul style="@_tipList">
                                                <li><b>Relative Strength</b> &mdash; 6-month return vs index</li>
                                                <li><b>SMA 50 Ratio</b> &mdash; price / 50-day MA (<span style="color: #26A69A;">&gt;1</span> = above trend)</li>
                                                <li><b>SMA 200 Ratio</b> &mdash; price / 200-day MA (<span style="color: #26A69A;">&gt;1</span> = long-term uptrend)</li>
                                                <li><b>Dist from 52w High</b> &mdash; <span style="color: #26A69A;">0%</span> = at peak, <span style="color: #EF5350;">-20%+</span> = significant drawdown</li>
                                            </ul>
                                            <div style="@_tipNote">Combined into the Momentum composite score.</div>
                                        </div>
                                    </TooltipContent>
                                </MudTooltip>
                                <MudSimpleTable Dense="true">
                                    <tbody>
                                        <tr><td>Relative Strength</td><td>@Pct(_detailDaily.RelativeStrength)</td></tr>
                                        <tr><td>SMA 50 Ratio</td><td>@F(_detailDaily.Sma50Ratio)</td></tr>
                                        <tr><td>SMA 200 Ratio</td><td>@F(_detailDaily.Sma200Ratio)</td></tr>
                                        <tr><td>Dist from 52w High</td><td>@Pct(_detailDaily.DistFrom52wHigh)</td></tr>
                                    </tbody>
                                </MudSimpleTable>

                                <MudDivider Class="my-3" />
                                <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                                    <ChildContent>
                                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.15);">Analyst Sentiment</MudText>
                                    </ChildContent>
                                    <TooltipContent>
                                        <div style="@_tipStyle">
                                            <div style="@_tipHead">Analyst Sentiment</div>
                                            <ul style="@_tipList">
                                                <li><b>Implied Upside</b> &mdash; (target price / current) &minus; 1</li>
                                                <li><b>Recommendation</b> scale:</li>
                                            </ul>
                                            <div style="padding-left: 16px; margin-bottom: 6px; font-size: 0.7rem;">
                                                <span style="color: #26A69A;">1.0</span> Strong Buy &bull;
                                                <span style="color: #26A69A;">2.0</span> Buy &bull;
                                                <span style="color: #FFA726;">3.0</span> Hold &bull;
                                                <span style="color: #EF5350;">4.0</span> Sell &bull;
                                                <span style="color: #EF5350;">5.0</span> Strong Sell
                                            </div>
                                            <div style="@_tipNote">Divergence flag triggers when price is declining but analysts remain bullish.</div>
                                        </div>
                                    </TooltipContent>
                                </MudTooltip>
                                <MudSimpleTable Dense="true">
                                    <tbody>
                                        <tr><td>Implied Upside</td><td>@Pct(_detailDaily.ImpliedUpside)</td></tr>
                                        <tr><td>Recommendation Mean</td><td>@F(_detailDaily.RecommendationMean)</td></tr>
                                        <tr>
                                            <td>Divergence Flag</td>
                                            <td>
                                                @if (_detailDaily.PriceFallingAnalystsBullish == true)
                                                {
                                                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">Price falling, analysts bullish</MudChip>
                                                }
                                                else
                                                {
                                                    <MudText>--</MudText>
                                                }
                                            </td>
                                        </tr>
                                    </tbody>
                                </MudSimpleTable>
                            </MudPaper>
                        </MudItem>
                    }

                    @if (_detailQuarterly is not null)
                    {
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-4" Elevation="2">
                                <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                                    <ChildContent>
                                        <span style="cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.2); width: fit-content;">
                                            <MudText Typo="Typo.h6" Style="margin: 0;">Quarterly Analytics</MudText>
                                        </span>
                                    </ChildContent>
                                    <TooltipContent>
                                        <div style="@_tipStyle">
                                            <div style="@_tipHead">Quarterly Scores</div>
                                            <div style="@_tipDesc">Derived from quarterly financial statements and governance data:</div>
                                            <ul style="@_tipList">
                                                <li><b>Quality</b> &mdash; profitability + balance sheet strength</li>
                                                <li><b>Governance</b> &mdash; ISS risk ratings (lower = better)</li>
                                            </ul>
                                            <div style="@_tipNote">Updated with each earnings cycle. Rank = position within the index.</div>
                                        </div>
                                    </TooltipContent>
                                </MudTooltip>
                                <MudText Typo="Typo.caption" Style="opacity: 0.5;">@_detailQuarterly.AsOfDate.ToString("yyyy-MM-dd")</MudText>
                                <MudSimpleTable Dense="true" Class="mt-2">
                                    <tbody>
                                        <ScoreRow Label="Quality" Score="@_detailQuarterly.QualityScore" Rank="@_detailQuarterly.QualityRank" />
                                        <ScoreRow Label="Governance" Score="@_detailQuarterly.GovernanceScore" Rank="@_detailQuarterly.GovernanceRank" />
                                    </tbody>
                                </MudSimpleTable>

                                <MudDivider Class="my-3" />
                                <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                                    <ChildContent>
                                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.15);">Quality Metrics</MudText>
                                    </ChildContent>
                                    <TooltipContent>
                                        <div style="@_tipStyle">
                                            <div style="@_tipHead">Quality Z-Scores</div>
                                            <div style="@_tipDesc">Z-scores vs index peers (<span style="color: #26A69A;">positive</span> = better than median):</div>
                                            <ul style="@_tipList">
                                                <li><b>Gross Margin</b> &mdash; pricing power</li>
                                                <li><b>ROE</b> &mdash; capital efficiency</li>
                                                <li><b>Operating Margin</b> &mdash; operational leverage</li>
                                                <li><b>Leverage Z</b> &mdash; inverted (lower debt = <span style="color: #26A69A;">higher</span> score)</li>
                                                <li><b>FCF Yield</b> &mdash; cash generation / market cap</li>
                                            </ul>
                                        </div>
                                    </TooltipContent>
                                </MudTooltip>
                                <MudSimpleTable Dense="true">
                                    <tbody>
                                        <tr><td>Gross Margin Z</td><td>@F(_detailQuarterly.GrossMarginZscore)</td></tr>
                                        <tr><td>ROE Z</td><td>@F(_detailQuarterly.RoeZscore)</td></tr>
                                        <tr><td>Operating Margin Z</td><td>@F(_detailQuarterly.OperatingMarginZscore)</td></tr>
                                        <tr><td>Leverage Z</td><td>@F(_detailQuarterly.LeverageZscore)</td></tr>
                                        <tr><td>FCF Yield</td><td>@Pct(_detailQuarterly.FcfYield)</td></tr>
                                    </tbody>
                                </MudSimpleTable>

                                <MudDivider Class="my-3" />
                                <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                                    <ChildContent>
                                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.15);">Financial Health</MudText>
                                    </ChildContent>
                                    <TooltipContent>
                                        <div style="@_tipStyle">
                                            <div style="@_tipHead">Health Flags</div>
                                            <div style="@_tipDesc">Binary flags from quarterly balance sheet:</div>
                                            <ul style="@_tipColorList">
                                                <li><span style="color: #42A5F5;">&#9679;</span> <b>Liquidity</b> &mdash; current ratio &lt; 1</li>
                                                <li><span style="color: #FFA726;">&#9679;</span> <b>Leverage</b> &mdash; D/E &gt; 200%</li>
                                                <li><span style="color: #EF5350;">&#9679;</span> <b>Cash Burn</b> &mdash; FCF &lt; 0</li>
                                                <li><span style="color: #AB47BC;">&#9679;</span> <b>Double Decline</b> &mdash; rev &amp; margin falling QoQ</li>
                                            </ul>
                                            <div style="margin: 6px 0 4px; font-size: 0.7rem; opacity: 0.5;">Risk levels:</div>
                                            <ul style="@_tipColorList">
                                                <li><span style="color: #26A69A;">0</span> healthy &bull; <span style="color: #42A5F5;">1</span> watch &bull; <span style="color: #FFA726;">2</span> warning &bull; <span style="color: #EF5350;">3+</span> critical</li>
                                            </ul>
                                        </div>
                                    </TooltipContent>
                                </MudTooltip>
                                <HealthBadge Level="@_detailQuarterly.HealthRiskLevel" FlagsCount="@_detailQuarterly.HealthFlagsCount" />
                                <MudSimpleTable Dense="true" Class="mt-2">
                                    <tbody>
                                        <FlagRow Label="Liquidity (CR < 1)" Flag="@_detailQuarterly.FlagLiquidity" />
                                        <FlagRow Label="Leverage (D/E > 200)" Flag="@_detailQuarterly.FlagLeverage" />
                                        <FlagRow Label="Cash Burn (FCF < 0)" Flag="@_detailQuarterly.FlagCashburn" />
                                        <FlagRow Label="Double Decline" Flag="@_detailQuarterly.FlagDoublDecline" />
                                    </tbody>
                                </MudSimpleTable>

                                <MudDivider Class="my-3" />
                                <MudTooltip Placement="Placement.Top" Color="Color.Transparent">
                                    <ChildContent>
                                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="cursor: help; border-bottom: 1px dotted rgba(255,255,255,0.15);">Governance (ISS Risk)</MudText>
                                    </ChildContent>
                                    <TooltipContent>
                                        <div style="@_tipStyle">
                                            <div style="@_tipHead">ISS Governance Risk</div>
                                            <div style="@_tipDesc">Risk scores on a 1–10 scale (<span style="color: #26A69A;">lower</span> = better governance):</div>
                                            <ul style="@_tipList">
                                                <li><b>Audit / Board / Compensation / Shareholder Rights</b></li>
                                                <li>Averaged into the <b>Overall Risk</b> score</li>
                                            </ul>
                                            <div style="margin: 6px 0 4px; font-size: 0.7rem; opacity: 0.5;">Thresholds:</div>
                                            <ul style="@_tipColorList">
                                                <li><span style="color: #26A69A;">1–3</span> low risk &bull; <span style="color: #FFA726;">4–6</span> moderate &bull; <span style="color: #EF5350;">7–10</span> high risk</li>
                                            </ul>
                                            <div style="@_tipNote">Gov vs Quality Gap: large positive = governance risk disproportionately high vs fundamentals. Beta measures systematic market risk.</div>
                                        </div>
                                    </TooltipContent>
                                </MudTooltip>
                                <MudSimpleTable Dense="true">
                                    <tbody>
                                        <tr><td>Overall Risk</td><td>@F(_detailQuarterly.OverallRisk)</td></tr>
                                        <tr><td>Audit Risk</td><td>@F(_detailQuarterly.AuditRisk)</td></tr>
                                        <tr><td>Board Risk</td><td>@F(_detailQuarterly.BoardRisk)</td></tr>
                                        <tr><td>Compensation Risk</td><td>@F(_detailQuarterly.CompensationRisk)</td></tr>
                                        <tr><td>Shareholder Rights Risk</td><td>@F(_detailQuarterly.ShareholderRightsRisk)</td></tr>
                                        <tr><td>Governance Score</td><td><strong>@F(_detailQuarterly.GovernanceScore)</strong></td></tr>
                                        <tr><td>Beta</td><td>@F(_detailQuarterly.Beta)</td></tr>
                                        <tr><td>Gov vs Quality Gap</td><td>@F(_detailQuarterly.GovernanceVsQuality)</td></tr>
                                    </tbody>
                                </MudSimpleTable>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudItem>

        <!-- Nav panel: index selector, search filter, and market-cap-ranked stock table.
             CSS order: -1 on desktop pushes it left of the detail panel. Sticky so it
             stays visible while scrolling the detail panel on long pages. -->
        <MudItem xs="12" md="4" Class="stock-nav-panel">
            <MudPaper Elevation="2" Class="pa-0" Style="position: sticky; top: 80px;">
                <div class="pa-3">
                    @if (_lastRefresh is not null)
                    {
                        <div class="mb-2">
                            <span style="font-size: 0.6rem; opacity: 0.3;">@_lastRefresh.Value.ToString("HH:mm:ss")</span>
                        </div>
                    }
                    <MudSelect T="string" Value="_filterIndex" ValueChanged="OnIndexFilterChanged"
                               Label="Index" Variant="Variant.Outlined" Dense="true" Class="mb-2">
                        @foreach (var idx in _indexKeys)
                        {
                            <MudSelectItem Value="@idx">@FormatIndexName(idx)</MudSelectItem>
                        }
                    </MudSelect>
                    <MudTextField @bind-Value="_searchText" Label="Search" Variant="Variant.Outlined"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true" DebounceInterval="300" Margin="Margin.Dense" />
                </div>
                <MudDivider />
                <div @ref="_navScrollContainer" style="overflow: auto; max-height: calc(100vh - 280px);">
                    <MudTable Items="@_navScores" Dense="true" Hover="true" Bordered="false"
                              Breakpoint="Breakpoint.None" Filter="@NavFilterFunc"
                              OnRowClick="OnNavRowClick" T="ScoreDaily"
                              RowStyleFunc="NavRowStyle"
                              SortLabel="Sort" Style="white-space: nowrap; font-size: 0.8rem;" Class="compact-table">
                        <HeaderContent>
                            <MudTh><MudTableSortLabel SortBy="@(new Func<ScoreDaily, object>(x => _mcapRank.GetValueOrDefault((_filterIndex ?? "", x.Symbol), 99)))" InitialDirection="SortDirection.Ascending">#</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="@(new Func<ScoreDaily, object>(x => x.Country ?? ""))"></MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="@(new Func<ScoreDaily, object>(x => x.Symbol))">Name</MudTableSortLabel></MudTh>
                            <MudTh Style="text-align: right;"><MudTableSortLabel SortBy="@(new Func<ScoreDaily, object>(x => x.MarketCap ?? 0))">Cap</MudTableSortLabel></MudTh>
                            <MudTh Style="text-align: right;"><MudTableSortLabel SortBy="@(new Func<ScoreDaily, object>(x => x.DayChangePct ?? 0))">Day</MudTableSortLabel></MudTh>
                            <MudTh Style="text-align: right;"><MudTableSortLabel SortBy="@(new Func<ScoreDaily, object>(x => x.FiveDayChangePct ?? 0))">5D</MudTableSortLabel></MudTh>
                            <MudTh Style="text-align: right;"><MudTableSortLabel SortBy="@(new Func<ScoreDaily, object>(x => x.YtdChangePct ?? 0))">YTD</MudTableSortLabel></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="#" Style="font-size: 0.8em;">@(_mcapRank.GetValueOrDefault((_filterIndex ?? "", context.Symbol)))</MudTd>
                            <MudTd Style="padding: 0 2px;"><img src="logos/@(context.Index)/@(context.Symbol).png" style="width: 18px; height: 18px; border-radius: 50%; object-fit: cover; vertical-align: middle;" onerror="this.style.display='none'" /></MudTd>
                            <MudTd DataLabel="Name">
                                <span style="font-weight: 600; font-size: 0.8rem;">@context.Symbol</span>
                                <div style="font-size: 0.7em; opacity: 0.5; max-width: 110px; overflow: hidden; text-overflow: ellipsis;">@context.ShortName</div>
                            </MudTd>
                            <MudTd DataLabel="Cap" Style="text-align: right; font-size: 0.8em; opacity: 0.7;">@FormatCap(context.MarketCap)</MudTd>
                            <MudTd DataLabel="Day" Style="@($"text-align: right; font-size: 0.8em; color: {ChgColor(context.DayChangePct)};")">@FormatChg(context.DayChangePct)</MudTd>
                            <MudTd DataLabel="5D" Style="@($"text-align: right; font-size: 0.8em; color: {ChgColor(context.FiveDayChangePct)};")">@FormatChg(context.FiveDayChangePct)</MudTd>
                            <MudTd DataLabel="YTD" Style="@($"text-align: right; font-size: 0.8em; color: {ChgColor(context.YtdChangePct)};")">@FormatChg(context.YtdChangePct)</MudTd>
                        </RowTemplate>
                    </MudTable>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    // ── Route parameters ──────────────────────────────────────────────
    [Parameter] public string? IndexKey { get; set; }
    [Parameter] public string? Symbol { get; set; }

    // ── State ─────────────────────────────────────────────────────────
    private bool _loading = true;
    private string? _filterIndex;
    private string _searchText = "";
    private List<string> _indexKeys = [];
    private List<StockRow> _stockRows = [];
    private ElementReference _navScrollContainer;
    private IJSObjectReference? _jsModule;
    private bool _scrollPending; // set true when we need OnAfterRenderAsync to scroll the nav table to the selected row
    private DateTime? _lastRefresh;
    private CancellationTokenSource? _refreshCts; // cancelled in DisposeAsync to stop the auto-refresh PeriodicTimer

    // Nav highlight (updates on click), detail panel (updates after data loads)
    private StockInfo? _navSelected;
    private StockInfo? _selectedStock;
    private ScoreDaily? _detailDaily;
    private ScoreQuarterly? _detailQuarterly;
    private List<OhlcvPrice> _allPrices = [];
    private int _selectedMonths = 12;

    // TradingView Lightweight Charts — series objects are created once in
    // OnAfterRenderAsync and reused across stock changes (SetData replaces points).
    private ChartComponent? _chart;
    private bool _chartReady;
    private bool _chartUpdatePending; // true when LoadStockDetail runs before the chart component is initialized
    private LightweightCharts.Blazor.Series.ISeriesApi<long>? _areaSeries;
    private LightweightCharts.Blazor.Series.ISeriesApi<long>? _candleSeries;
    private LightweightCharts.Blazor.Series.ISeriesApi<long>? _volumeSeries;
    private LightweightCharts.Blazor.Series.ISeriesApi<long>? _ma30Series;
    private LightweightCharts.Blazor.Series.ISeriesApi<long>? _ma90Series;
    private LightweightCharts.Blazor.Charts.ITimeScaleApi<long>? _timeScale;
    private LightweightCharts.Blazor.Series.IPriceLine<long>? _currentPriceLine;
    private LightweightCharts.Blazor.Series.IPriceLine<long>? _highPriceLine;
    private LightweightCharts.Blazor.Series.IPriceLine<long>? _lowPriceLine;
    // Concurrency guards: rapid stock switches or pan/zoom can cause overlapping async
    // calls. Each guard is an incrementing ID — if the ID has moved on by the time an
    // await resumes, the continuation abandons itself so stale results aren't applied.
    private int _chartUpdateId;
    private int _priceLineUpdateId;
    private CancellationTokenSource? _priceLineCts; // debounce: OnVisibleRangeChanged cancels/restarts a 120ms delay

    // Chart.js — stock radar + governance bar (init returns false if canvas not in DOM yet)
    private bool _stockRadarReady;
    private bool _govChartReady;
    private bool _chartJsPending; // true when LoadStockDetail runs before Chart.js canvases are ready

    // Price header
    private OhlcvPrice? _latestCandle;
    private double? _priceChangePct;
    private string _currencySymbol = "";

    // Hover overlay
    private OhlcvPrice? _hoverCandle;
    private OhlcvPrice? _hoverPrevCandle;
    private double? _hoverMa30;
    private double? _hoverMa90;
    private long? _lastHoverTime;
    private double _hoverX;
    private double _hoverY;
    private double _chartWidth = 800;
    private double _chartHeight = 420;
    private ElementReference _chartContainer;

    // Data for crosshair lookup (full range) + filtered subset for period high/low
    private double?[] _allMa30 = [];
    private double?[] _allMa90 = [];
    private Dictionary<long, int> _tsIndex = new();
    private List<OhlcvPrice> _filteredPrices = [];

    private static readonly (string Label, int Months)[] _ranges =
    [
        ("1M", 1), ("3M", 3), ("6M", 6), ("1Y", 12), ("3Y", 36), ("All", 0)
    ];

    private record StockRow(StockInfo Stock, ScoreDaily? Daily, ScoreQuarterly? Quarterly);

    private Dictionary<(string, string), int> _mcapRank = new();
    private List<ScoreDaily> _navScores = [];

    private bool NavFilterFunc(ScoreDaily item) =>
        string.IsNullOrEmpty(_searchText)
        || item.Symbol.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
        || (item.ShortName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false);

    private string NavRowStyle(ScoreDaily item, int index) =>
        _navSelected?.Symbol == item.Symbol && _navSelected?.Index == _filterIndex
            ? "background: rgba(66,165,245,0.15); cursor: pointer;"
            : "cursor: pointer;";

    // Resolve the clicked nav row back to a StockRow and load its detail panel.
    private async Task OnNavRowClick(TableRowClickEventArgs<ScoreDaily> args)
    {
        var stock = _stockRows.FirstOrDefault(r =>
            r.Stock.Index == _filterIndex && r.Stock.Symbol == args.Item!.Symbol);
        if (stock is not null)
        {
            await SelectStock(stock.Stock);
            Nav.NavigateTo($"/stocks/{stock.Stock.Index}/{stock.Stock.Symbol}", replace: true);
        }
    }

    private void UpdateNavScores()
    {
        _navScores = _stockRows
            .Where(r => r.Stock.Index == _filterIndex && r.Daily is not null)
            .OrderByDescending(r => r.Daily!.MarketCap ?? 0)
            .Select(r => r.Daily!)
            .ToList();
    }

    // Loads all stocks, scores, and index keys in parallel. If the URL contains
    // deep-link parameters (/stocks/{IndexKey}/{Symbol}), selects that stock;
    // otherwise selects the largest stock by market cap in the active index.
    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        var stocksTask = StockRepo.GetStocksAsync();
        var dailyTask = ScoresRepo.GetDailyScoresAsync();
        var quarterlyTask = ScoresRepo.GetQuarterlyScoresAsync();
        var keysTask = StockRepo.GetIndexKeysAsync();

        await Task.WhenAll(stocksTask, dailyTask, quarterlyTask, keysTask);

        var stocks = (await stocksTask).ToList();
        var daily = (await dailyTask).ToDictionary(d => (d.Index, d.Symbol));
        var quarterly = (await quarterlyTask).ToDictionary(q => (q.Index, q.Symbol));
        _indexKeys = (await keysTask).ToList();

        _stockRows = stocks.Select(s => new StockRow(
            s,
            daily.GetValueOrDefault((s.Index, s.Symbol)),
            quarterly.GetValueOrDefault((s.Index, s.Symbol))
        )).ToList();

        // Compute market cap ranks per index
        _mcapRank.Clear();
        foreach (var idx in _indexKeys)
        {
            var ranked = _stockRows
                .Where(r => r.Stock.Index == idx && r.Daily?.MarketCap is not null)
                .OrderByDescending(r => r.Daily!.MarketCap!.Value)
                .Select((r, i) => (r.Stock.Symbol, Rank: i + 1));
            foreach (var (sym, rank) in ranked)
                _mcapRank[(idx, sym)] = rank;
        }

        // Use shared state unless URL specifies an index
        _filterIndex = _indexKeys.Contains(IdxState.SelectedIndex)
            ? IdxState.SelectedIndex
            : _indexKeys.FirstOrDefault() ?? "euro_stoxx_50";
        UpdateNavScores();

        if (!string.IsNullOrEmpty(IndexKey) && !string.IsNullOrEmpty(Symbol))
        {
            _filterIndex = IndexKey;
            IdxState.SelectedIndex = IndexKey;
            UpdateNavScores();
            var match = _stockRows.FirstOrDefault(r =>
                r.Stock.Index == IndexKey && r.Stock.Symbol.Equals(Symbol, StringComparison.OrdinalIgnoreCase));
            if (match is not null)
            {
                await LoadStockDetail(match.Stock);
                _scrollPending = true;
            }
        }
        else
        {
            var top = _stockRows
                .Where(r => r.Stock.Index == _filterIndex && r.Daily?.MarketCap is not null)
                .OrderByDescending(r => r.Daily!.MarketCap!.Value)
                .FirstOrDefault();
            if (top is not null)
                await LoadStockDetail(top.Stock);
        }

        _lastRefresh = DateTime.Now;
        _loading = false;

        // Start 60-second auto-refresh loop
        _refreshCts = new CancellationTokenSource();
        _ = AutoRefreshLoop(_refreshCts.Token);
    }

    // Refreshes daily + quarterly scores every 60 seconds to keep the nav table
    // and detail panel current during market hours. The PeriodicTimer is cancelled
    // via _refreshCts in DisposeAsync — WaitForNextTickAsync throws
    // OperationCanceledException which breaks the loop cleanly.
    private async Task AutoRefreshLoop(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromMinutes(1));
        while (!ct.IsCancellationRequested && await timer.WaitForNextTickAsync(ct))
        {
            try
            {
                var dailyTask = ScoresRepo.GetDailyScoresAsync();
                var quarterlyTask = ScoresRepo.GetQuarterlyScoresAsync();
                await Task.WhenAll(dailyTask, quarterlyTask);

                var daily = (await dailyTask).ToDictionary(d => (d.Index, d.Symbol));
                var quarterly = (await quarterlyTask).ToDictionary(q => (q.Index, q.Symbol));

                _stockRows = _stockRows.Select(r => new StockRow(
                    r.Stock,
                    daily.GetValueOrDefault((r.Stock.Index, r.Stock.Symbol)),
                    quarterly.GetValueOrDefault((r.Stock.Index, r.Stock.Symbol))
                )).ToList();

                UpdateNavScores();

                // Refresh detail panel if a stock is selected
                if (_selectedStock is not null)
                {
                    var row = _stockRows.FirstOrDefault(r =>
                        r.Stock.Index == _selectedStock.Index && r.Stock.Symbol == _selectedStock.Symbol);
                    if (row is not null)
                    {
                        _detailDaily = row.Daily;
                        _detailQuarterly = row.Quarterly;
                    }
                }

                _lastRefresh = DateTime.Now;
                await InvokeAsync(StateHasChanged);
            }
            catch (OperationCanceledException) { break; }
            catch { /* swallow transient DB errors, retry next tick */ }
        }
    }

    // First render: import the co-located JS module and scroll to any deep-linked row.
    // Also initializes the chart on first render: creates all five series objects once
    // (they are reused across stock changes — only their data is replaced via SetData).
    // If _chartUpdatePending is true, LoadStockDetail ran before the chart was ready,
    // so we replay the pending UpdateChart call now.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import",
                "./Components/Pages/StockExplorer.razor.js");
        }

        if (_scrollPending && _jsModule is not null)
        {
            _scrollPending = false;
            await _jsModule.InvokeVoidAsync("scrollToSelectedRow", _navScrollContainer);
        }

        if (_chart is not null && !_chartReady)
        {
            await _chart.InitializationCompleted;

            await _chart.ApplyOptions(new LightweightCharts.Blazor.Customization.Chart.ChartOptions
            {
                AutoSize = true,
                Layout = new LayoutOptions
                {
                    Background = new SolidColor { Color = Clr("#1E1E2D") },
                    TextColor = Clr("#A0AEC0"),
                    FontFamily = "Inter",
                    FontSize = 12
                },
                Grid = new GridOptions
                {
                    VerticalLines = new GridLineOptions { Color = Clr(255, 255, 255, 10) },
                    HorizontalLines = new GridLineOptions { Color = Clr(255, 255, 255, 10) }
                },
                RightPriceScale = new PriceScaleOptions { BorderColor = Clr(255, 255, 255, 26), MinimumWidth = 56 },
                OverlayPriceScale = new LightweightCharts.Blazor.Customization.Chart.BasePriceScaleOptions
                {
                    ScaleMargins = new LightweightCharts.Blazor.Customization.PriceScaleMargins { Top = 0.9, Bottom = 0 }
                },
                Crosshair = new LightweightCharts.Blazor.Customization.Chart.CrosshairOptions
                {
                    Mode = LightweightCharts.Blazor.Customization.Chart.CrosshairMode.Magnet
                },
                TimeScale = new TimeScaleOptions
                {
                    BorderColor = Clr(255, 255, 255, 26),
                    FixLeftEdge = true,
                    FixRightEdge = true,
                    RightOffset = 0,
                    LockVisibleTimeRangeOnResize = true
                }
            });

            // Create all series once — they persist across stock changes
            _areaSeries = await _chart.AddSeries<AreaStyleOptions>(
                SeriesType.Area,
                new AreaStyleOptions
                {
                    TopColor = Clr(38, 166, 154, 18),
                    BottomColor = Clr(38, 166, 154, 3),
                    LineVisible = false,
                    CrosshairMarkerVisible = false,
                    LastValueVisible = false,
                    PriceLineVisible = false
                });

            _candleSeries = await _chart.AddSeries<CandlestickStyleOptions>(
                SeriesType.Candlestick,
                new CandlestickStyleOptions
                {
                    UpColor = Clr("#26A69A"),
                    DownColor = Clr("#EF5350"),
                    BorderUpColor = Clr("#26A69A"),
                    BorderDownColor = Clr("#EF5350"),
                    WickUpColor = Clr("#26A69A"),
                    WickDownColor = Clr("#EF5350"),
                    LastValueVisible = false,
                    PriceLineVisible = false
                });

            _ma30Series = await _chart.AddSeries<LineStyleOptions>(
                SeriesType.Line,
                new LineStyleOptions
                {
                    Color = Clr("#42A5F5"),
                    LineWidth = 1,
                    LineStyle = LightweightCharts.Blazor.Customization.Enums.LineStyle.Dashed,
                    CrosshairMarkerVisible = false,
                    LastValueVisible = false,
                    PriceLineVisible = false
                });

            _ma90Series = await _chart.AddSeries<LineStyleOptions>(
                SeriesType.Line,
                new LineStyleOptions
                {
                    Color = Clr("#AB47BC"),
                    LineWidth = 1,
                    LineStyle = LightweightCharts.Blazor.Customization.Enums.LineStyle.Dashed,
                    CrosshairMarkerVisible = false,
                    LastValueVisible = false,
                    PriceLineVisible = false
                });

            _volumeSeries = await _chart.AddSeries<HistogramStyleOptions>(
                SeriesType.Histogram,
                new HistogramStyleOptions
                {
                    Color = Clr(160, 170, 180, 80),
                    PriceScaleId = "volume",
                    LastValueVisible = false,
                    PriceLineVisible = false
                });

            _chart.CrosshairMoved += OnCrosshairMoved;
            _timeScale = await _chart.TimeScale();
            _timeScale.VisibleTimeRangeChanged += OnVisibleRangeChanged;
            _chartReady = true;
            await MeasureChartContainerAsync();

            if (_chartUpdatePending || _allPrices.Count > 0)
            {
                _chartUpdatePending = false;
                await UpdateChart();
            }

            StateHasChanged();
        }

        // Chart.js radar + governance: canvases appear after _detailDaily/_detailQuarterly are set
        if (_jsModule is not null && _selectedStock is not null)
        {
            if (!_stockRadarReady && _detailDaily is not null)
                await InitStockRadar();
            if (!_govChartReady && _detailQuarterly is not null)
                await InitGovChart();
            if (_chartJsPending)
            {
                _chartJsPending = false;
                if (_stockRadarReady) await UpdateStockRadar();
                if (_govChartReady) await UpdateGovChart();
            }
        }
    }

    // Crosshair handler: looks up the hovered timestamp in _tsIndex to populate
    // the OHLCV tooltip overlay. The _disposed guard prevents JS interop calls
    // after the Blazor circuit has been torn down on navigation.
    private void OnCrosshairMoved(object? sender, LightweightCharts.Blazor.Models.Events.MouseEventParams<long> e)
    {
        if (_disposed) return;
        try
        {
            if (e.Time is null || e.Time == _lastHoverTime)
            {
                if (e.Time is null && _hoverCandle is not null)
                {
                    _hoverCandle = null;
                    _hoverPrevCandle = null;
                    _hoverMa30 = null;
                    _hoverMa90 = null;
                    _lastHoverTime = null;
                    InvokeAsync(StateHasChanged);
                }
                return;
            }

            _lastHoverTime = e.Time;
            if (e.Point is not null)
            {
                _hoverX = e.Point.X;
                _hoverY = e.Point.Y;
            }
            if (_tsIndex.TryGetValue(e.Time.Value, out var idx))
            {
                _hoverCandle = _allPrices[idx];
                _hoverPrevCandle = idx > 0 ? _allPrices[idx - 1] : null;
                _hoverMa30 = _allMa30[idx];
                _hoverMa90 = _allMa90[idx];
                InvokeAsync(StateHasChanged);
            }
        }
        catch (ObjectDisposedException) { }
    }

    // Handles deep-link URL navigation (/stocks/{IndexKey}/{Symbol}) when the user
    // clicks a link that changes route parameters without a full page reload.
    // Skips if the same stock is already selected (early-exit guard).
    protected override async Task OnParametersSetAsync()
    {
        if (_stockRows.Count == 0) return;
        if (string.IsNullOrEmpty(IndexKey) || string.IsNullOrEmpty(Symbol)) return;
        if (_navSelected?.Index == IndexKey &&
            _navSelected?.Symbol.Equals(Symbol, StringComparison.OrdinalIgnoreCase) == true) return;

        _filterIndex = IndexKey;
        IdxState.SelectedIndex = IndexKey;
        UpdateNavScores();
        var match = _stockRows.FirstOrDefault(r =>
            r.Stock.Index == IndexKey && r.Stock.Symbol.Equals(Symbol, StringComparison.OrdinalIgnoreCase));
        if (match is not null)
        {
            await LoadStockDetail(match.Stock);
            _scrollPending = true;
        }
    }

    private async Task SelectStock(StockInfo stock) => await LoadStockDetail(stock);

    // Fetches scores + full OHLCV history for the selected stock, then triggers
    // chart rendering. If the chart component isn't initialized yet (e.g., on
    // initial deep-link load), sets _chartUpdatePending so OnAfterRenderAsync
    // will replay the update once the chart is ready.
    private async Task LoadStockDetail(StockInfo stock)
    {
        _navSelected = stock;

        var dailyTask = ScoresRepo.GetDailyScoreAsync(stock.Index, stock.Symbol);
        var quarterlyTask = ScoresRepo.GetQuarterlyScoreAsync(stock.Index, stock.Symbol);
        var pricesTask = StockRepo.GetOhlcvAsync(stock.Index, stock.Symbol);

        await Task.WhenAll(dailyTask, quarterlyTask, pricesTask);

        _detailDaily = await dailyTask;
        _detailQuarterly = await quarterlyTask;
        _allPrices = (await pricesTask).ToList();
        _currencySymbol = CurrencySymbol(stock.Index);

        _latestCandle = _allPrices.Count > 0 ? _allPrices[^1] : null;
        if (_allPrices.Count >= 2)
        {
            var prev = _allPrices[^2].RawClose ?? 0;
            var curr = _allPrices[^1].RawClose ?? 0;
            _priceChangePct = prev != 0 ? (curr - prev) / prev * 100 : null;
        }
        else _priceChangePct = null;

        _hoverCandle = null;
        _lastHoverTime = null;
        _selectedStock = stock;

        if (_chartReady)
            await UpdateChart();
        else
            _chartUpdatePending = true;

        // Update Chart.js charts (or defer to OnAfterRenderAsync if canvases aren't in DOM yet)
        if (_stockRadarReady)
            await UpdateStockRadar();
        if (_govChartReady)
            await UpdateGovChart();
        if (!_stockRadarReady || !_govChartReady)
            _chartJsPending = true;
    }

    private async Task SetPriceRange(int months)
    {
        _selectedMonths = months;
        if (_chartReady)
            await UpdateChart();
    }

    // Measures the chart container's pixel dimensions via JS interop so the hover
    // tooltip can flip sides when it would overflow the right or bottom edge.
    private async Task MeasureChartContainerAsync()
    {
        try
        {
            var rect = await JS.InvokeAsync<BoundingRect>(
                "eval", "(function(el){ var r = el.getBoundingClientRect(); return { width: r.width, height: r.height }; })(arguments[0])", _chartContainer);
            if (rect.Width > 0) _chartWidth = rect.Width;
            if (rect.Height > 0) _chartHeight = rect.Height;
        }
        catch { /* Circuit may be disconnected */ }
    }

    private record BoundingRect(double Width, double Height);

    // Pushes OHLCV + MA + volume data into the five chart series and sets the
    // visible time range for the selected period. The _chartUpdateId concurrency
    // guard prevents stale price lines: if a second call arrives while an earlier
    // one is still awaiting JS interop, the earlier call detects its ID is stale
    // and abandons itself.
    //
    // IMPORTANT: the five SetData calls below MUST be sequential (not Task.WhenAll).
    // Parallel JS interop calls deadlock the Blazor Server SignalR circuit because
    // the single-threaded synchronization context cannot process interleaved responses.
    private async Task UpdateChart()
    {
        if (_chart is null || !_chartReady) return;
        var updateId = ++_chartUpdateId;
        await MeasureChartContainerAsync();

        // Build lookup arrays from full data (used by crosshair hover)
        _allMa30 = _allPrices.Select(p => p.Sma30).ToArray();
        _allMa90 = _allPrices.Select(p => p.Sma90).ToArray();
        _tsIndex.Clear();
        for (int i = 0; i < _allPrices.Count; i++)
            _tsIndex[ToUnix(_allPrices[i].Date)] = i;

        // Filtered subset for period high/low price lines
        int startIdx = 0;
        if (_selectedMonths > 0)
        {
            var cutoff = DateTime.Today.AddMonths(-_selectedMonths);
            startIdx = _allPrices.FindIndex(p => p.Date >= cutoff);
            if (startIdx < 0) startIdx = _allPrices.Count;
        }
        _filteredPrices = _allPrices.GetRange(startIdx, _allPrices.Count - startIdx);

        if (_allPrices.Count == 0)
        {
            await _jsModule!.InvokeVoidAsync("batchUpdateStockChart",
                new object[]
                {
                    new { series = _areaSeries!.JsObjectReference, data = Array.Empty<object>() },
                    new { series = _candleSeries!.JsObjectReference, data = Array.Empty<object>() },
                    new { series = _ma30Series!.JsObjectReference, data = Array.Empty<object>() },
                    new { series = _ma90Series!.JsObjectReference, data = Array.Empty<object>() },
                    new { series = _volumeSeries!.JsObjectReference, data = Array.Empty<object>() }
                },
                _timeScale!.JsObjectReference, null, null);
            return;
        }

        // Candle data (full range — period is controlled via visible range)
        var candleData = _allPrices.Select(p => new CandlestickData<long>
        {
            Time = ToUnix(p.Date),
            Open = p.Open ?? 0,
            High = p.High ?? 0,
            Low = p.Low ?? 0,
            Close = p.Close ?? 0
        }).ToArray();

        // Area data (close prices for the fill)
        var areaData = _allPrices.Select(p => new AreaData<long>
        {
            Time = ToUnix(p.Date),
            Value = p.Close ?? 0
        }).ToArray();

        // MA data from SQL (skip nulls)
        var ma30Data = _allPrices
            .Where(p => p.Sma30.HasValue)
            .Select(p => new LineData<long> { Time = ToUnix(p.Date), Value = p.Sma30!.Value })
            .ToArray();

        var ma90Data = _allPrices
            .Where(p => p.Sma90.HasValue)
            .Select(p => new LineData<long> { Time = ToUnix(p.Date), Value = p.Sma90!.Value })
            .ToArray();

        // Volume histogram: alpha scales linearly with the ratio to max volume
        // (50 = baseline visibility, up to 230 for the highest-volume day).
        var maxVol = _allPrices.Max(p => p.Volume ?? 0);
        if (maxVol == 0) maxVol = 1;
        var volumeData = _allPrices.Select(p =>
        {
            var ratio = (double)(p.Volume ?? 0) / maxVol;
            var alpha = (int)(50 + 180 * ratio);
            return new HistogramData<long>
            {
                Time = ToUnix(p.Date),
                Value = p.Volume ?? 0,
                Color = Clr(160, 170, 185, alpha)
            };
        }).ToArray();

        // Batch all 5 SetData + SetVisibleRange into a single JS interop call.
        // Replaces 6 sequential SignalR round-trips with 1 on every stock switch.
        var seriesData = new object[]
        {
            new { series = _areaSeries!.JsObjectReference, data = (object)areaData },
            new { series = _candleSeries!.JsObjectReference, data = (object)candleData },
            new { series = _ma30Series!.JsObjectReference, data = (object)ma30Data },
            new { series = _ma90Series!.JsObjectReference, data = (object)ma90Data },
            new { series = _volumeSeries!.JsObjectReference, data = (object)volumeData }
        };
        long? from = null, to = null;
        if (_selectedMonths > 0 && _filteredPrices.Count > 0)
        {
            from = ToUnix(_filteredPrices[0].Date);
            to = ToUnix(_filteredPrices[^1].Date);
        }
        await _jsModule!.InvokeVoidAsync("batchUpdateStockChart",
            seriesData, _timeScale!.JsObjectReference, from, to);

        // Reset hover
        _hoverCandle = null;
        _lastHoverTime = null;
    }

    // Fires rapidly during pan/zoom. Uses a cancel-and-restart debounce pattern:
    // each call cancels the previous CTS and starts a 120ms delay. Only the last
    // event in a burst actually reaches UpdatePriceLines, avoiding JS interop floods.
    // The _disposed guard prevents calls after the Blazor circuit is torn down.
    private void OnVisibleRangeChanged(object? sender, LightweightCharts.Blazor.Models.TimeRange? e)
    {
        if (_disposed || e is null || _candleSeries is null) return;
        try
        {
            _priceLineCts?.Cancel();
            _priceLineCts = new CancellationTokenSource();
            var cts = _priceLineCts;
            var from = e.From;
            var to = e.To;
            InvokeAsync(async () =>
            {
                try
                {
                    await Task.Delay(120, cts.Token);
                    if (!cts.IsCancellationRequested && !_disposed)
                        await UpdatePriceLines(from, to);
                }
                catch (TaskCanceledException) { }
                catch (ObjectDisposedException) { }
                catch (Microsoft.JSInterop.JSDisconnectedException) { }
            });
        }
        catch (ObjectDisposedException) { }
    }

    // Draws three horizontal price lines on the visible range:
    //   - Current close: white dashed
    //   - Period high:   green dotted (hidden if within 0.1% of current — avoids overlap)
    //   - Period low:    red dotted   (same proximity threshold)
    // Uses _priceLineUpdateId as a concurrency guard — if a newer call has started by the
    // time an await resumes, the stale continuation exits early to avoid ghost lines.
    private async Task UpdatePriceLines(long fromTs, long toTs)
    {
        var updateId = ++_priceLineUpdateId;

        // Remove old price lines before creating new ones
        if (_currentPriceLine is not null)
        {
            try { await _candleSeries!.RemovePriceLine(_currentPriceLine); } catch { }
            _currentPriceLine = null;
        }
        if (_highPriceLine is not null)
        {
            try { await _candleSeries!.RemovePriceLine(_highPriceLine); } catch { }
            _highPriceLine = null;
        }
        if (_lowPriceLine is not null)
        {
            try { await _candleSeries!.RemovePriceLine(_lowPriceLine); } catch { }
            _lowPriceLine = null;
        }

        if (updateId != _priceLineUpdateId) return;

        // Find prices within visible range
        var visiblePrices = _allPrices
            .Where(p => { var ts = ToUnix(p.Date); return ts >= fromTs && ts <= toTs; })
            .ToList();

        if (visiblePrices.Count == 0) return;

        // Current price = latest close in visible range
        var currentPrice = visiblePrices[^1].Close;
        if (currentPrice is not null)
        {
            _currentPriceLine = await _candleSeries!.CreatePriceLine(
                new LightweightCharts.Blazor.Customization.Series.PriceLineOptions
                {
                    Price = currentPrice.Value,
                    Color = Clr(255, 255, 255, 80),
                    LineWidth = 1,
                    LineStyle = LightweightCharts.Blazor.Customization.Enums.LineStyle.Dashed,
                    AxisLabelVisible = true,
                    LineVisible = true
                });
        }
        if (updateId != _priceLineUpdateId) return;

        var visibleHigh = visiblePrices.Max(p => p.High ?? 0);
        var visibleLow = visiblePrices.Where(p => p.Low > 0).Min(p => p.Low!.Value);

        if (currentPrice is null || Math.Abs(visibleHigh - currentPrice.Value) > currentPrice.Value * 0.001)
        {
            _highPriceLine = await _candleSeries!.CreatePriceLine(
                new LightweightCharts.Blazor.Customization.Series.PriceLineOptions
                {
                    Price = visibleHigh,
                    Color = Clr(38, 166, 154, 60),
                    LineWidth = 1,
                    LineStyle = LightweightCharts.Blazor.Customization.Enums.LineStyle.Dotted,
                    AxisLabelVisible = true,
                    LineVisible = true
                });
        }
        if (updateId != _priceLineUpdateId) return;

        if (currentPrice is null || Math.Abs(visibleLow - currentPrice.Value) > currentPrice.Value * 0.001)
        {
            _lowPriceLine = await _candleSeries!.CreatePriceLine(
                new LightweightCharts.Blazor.Customization.Series.PriceLineOptions
                {
                    Price = visibleLow,
                    Color = Clr(239, 83, 80, 60),
                    LineWidth = 1,
                    LineStyle = LightweightCharts.Blazor.Customization.Enums.LineStyle.Dotted,
                    AxisLabelVisible = true,
                    LineVisible = true
                });
        }
    }

    // Switching the index filter: updates shared state, rebuilds the nav list,
    // and auto-selects the largest stock by market cap in the new index.
    private async Task OnIndexFilterChanged(string? value)
    {
        _filterIndex = value;
        if (value is not null) IdxState.SelectedIndex = value;
        UpdateNavScores();
        var top = _stockRows
            .Where(r => r.Stock.Index == _filterIndex && r.Daily?.MarketCap is not null)
            .OrderByDescending(r => r.Daily!.MarketCap!.Value)
            .FirstOrDefault();
        if (top is not null)
            await LoadStockDetail(top.Stock);
    }

    // ── Chart.js: Stock Radar + Governance ─────────────────────────────

    // Returns [Value, Momentum, Sentiment, Quality, Governance] as 0–100 percentile ranks within the index.
    private double[] ComputeStockRadarData()
    {
        if (_selectedStock is null || _detailDaily is null) return [50, 50, 50, 50, 50];

        var peers = _stockRows.Where(r => r.Stock.Index == _selectedStock.Index).ToList();
        var n = peers.Count;
        if (n == 0) return [50, 50, 50, 50, 50];

        static double percentile(double? rank, int total)
            => rank.HasValue && total > 0 ? (1.0 - (rank.Value - 1.0) / total) * 100.0 : 50.0;

        return
        [
            percentile(_detailDaily.RelativeValueRank, n),
            percentile(_detailDaily.MomentumRank, n),
            percentile(_detailDaily.SentimentRank, n),
            _detailQuarterly is not null ? percentile(_detailQuarterly.QualityRank, n) : 50,
            _detailQuarterly is not null ? percentile(_detailQuarterly.GovernanceRank, n) : 50,
        ];
    }

    private double[] ComputeGovChartData()
    {
        if (_detailQuarterly is null) return [0, 0, 0, 0];
        return
        [
            _detailQuarterly.AuditRisk ?? 0,
            _detailQuarterly.BoardRisk ?? 0,
            _detailQuarterly.CompensationRisk ?? 0,
            _detailQuarterly.ShareholderRightsRisk ?? 0,
        ];
    }

    private async Task InitStockRadar()
    {
        var data = ComputeStockRadarData();
        var labels = new[] { "Value", "Momentum", "Sentiment", "Quality", "Governance" };
        var created = await _jsModule!.InvokeAsync<bool>("initStockRadar", "stockRadarChart", labels, data, _selectedStock?.Symbol ?? "");
        _stockRadarReady = created;
    }

    private async Task InitGovChart()
    {
        var data = ComputeGovChartData();
        var labels = new[] { "Audit", "Board", "Compensation", "Shareholder" };
        var created = await _jsModule!.InvokeAsync<bool>("initGovChart", "govChart", labels, data);
        _govChartReady = created;
    }

    private async Task UpdateStockRadar()
    {
        var data = ComputeStockRadarData();
        await _jsModule!.InvokeVoidAsync("updateStockRadar", data, _selectedStock?.Symbol ?? "");
    }

    private async Task UpdateGovChart()
    {
        var data = ComputeGovChartData();
        await _jsModule!.InvokeVoidAsync("updateGovChart", data);
    }

